//LN++ ManagerModule контейнера промптов LN_МСРПромпты.
// Реализует MCP-методы prompts/list + prompts/get для пяти готовых сценариев AI-агента 1С:
//   refactor_bsl       — рефакторинг куска BSL (антипаттерны, читаемость, производительность)
//   code_review_bsl    — code review c указанием конкретных нарушений 1С-стандартов
//   query_generator    — построение текста запроса 1С по бизнес-формулировке + перечню объектов МД
//   error_explainer    — объяснение текста ошибки 1С с предложением минимального фикса
//   schema_to_form     — заготовка управляемой формы по структуре объекта (реквизиты + ТЧ)
//
// Контракт vendor:
//   ДобавитьПромпты(Промпты) — заполняет ТЗ {Имя, Описание, Параметры (JSON)}.
//   ПолучитьПромпт(ИмяПромпта, Аргументы) — возвращает Структуру MCP-формата
//     { description, messages: [{role, content: {type:"text", text:"..."} }, …] }.

#Область ПрограммныйИнтерфейс

Процедура ДобавитьПромпты(Промпты) Экспорт

	Параметры = Новый Массив;
	Параметры.Добавить(mcp_Метаданные.ПараметрПромпта("code", "BSL-код, который нужно отрефакторить", Истина));
	Параметры.Добавить(mcp_Метаданные.ПараметрПромпта("focus", "Опц.: ""perf"" | ""style"" | ""safety"" | ""all""", Ложь));
	mcp_Метаданные.ДобавитьПромпт(Промпты, "refactor_bsl",
		"Безопасный рефакторинг BSL-кода: устранение антипаттернов, оптимизация запросов, типобезопасность.",
		mcp_Метаданные.ПараметрыПромпта(Параметры));

	Параметры = Новый Массив;
	Параметры.Добавить(mcp_Метаданные.ПараметрПромпта("code", "BSL-код для code review", Истина));
	Параметры.Добавить(mcp_Метаданные.ПараметрПромпта("strictness", "Опц.: ""lenient"" | ""normal"" | ""strict""", Ложь));
	mcp_Метаданные.ДобавитьПромпт(Промпты, "code_review_bsl",
		"Code review с проверкой по 1С:Стандартам и БСП-конвенциям. Возвращает severity + ссылку на стандарт.",
		mcp_Метаданные.ПараметрыПромпта(Параметры));

	Параметры = Новый Массив;
	Параметры.Добавить(mcp_Метаданные.ПараметрПромпта("task", "Бизнес-задача в свободной форме", Истина));
	Параметры.Добавить(mcp_Метаданные.ПараметрПромпта("metadata_objects", "CSV полных имён МД через запятую (Документ.X, Справочник.Y, ...)", Ложь));
	Параметры.Добавить(mcp_Метаданные.ПараметрПромпта("dialect", "Опц.: ""1c_query"" (по умолчанию) | ""dcs""", Ложь));
	mcp_Метаданные.ДобавитьПромпт(Промпты, "query_generator",
		"Генерирует текст запроса 1С (или СКД) по бизнес-задаче и перечню объектов МД. Перед выполнением — validate_query.",
		mcp_Метаданные.ПараметрыПромпта(Параметры));

	Параметры = Новый Массив;
	Параметры.Добавить(mcp_Метаданные.ПараметрПромпта("error_text", "Текст ошибки 1С / стек выполнения", Истина));
	Параметры.Добавить(mcp_Метаданные.ПараметрПромпта("code_context", "Опц.: фрагмент кода рядом с ошибкой", Ложь));
	mcp_Метаданные.ДобавитьПромпт(Промпты, "error_explainer",
		"Объяснение ошибки 1С на русском с указанием вероятной причины и минимального фикса.",
		mcp_Метаданные.ПараметрыПромпта(Параметры));

	Параметры = Новый Массив;
	Параметры.Добавить(mcp_Метаданные.ПараметрПромпта("object_name", "Полное имя объекта МД (например, Документ.РеализацияТоваровУслуг)", Истина));
	Параметры.Добавить(mcp_Метаданные.ПараметрПромпта("form_kind", "Опц.: ""object"" (по умолчанию) | ""list"" | ""choice""", Ложь));
	mcp_Метаданные.ДобавитьПромпт(Промпты, "schema_to_form",
		"Создаёт заготовку управляемой формы (XML + модуль) по реквизитам и табличным частям объекта МД."
			+ " Вызывает get_metadata, чтобы реально получить состав. Затем выдаёт Form.xml/Form.Module.bsl.",
		mcp_Метаданные.ПараметрыПромпта(Параметры));

КонецПроцедуры

Функция ПолучитьПромпт(ИмяПромпта, Аргументы) Экспорт

	Если ИмяПромпта = "refactor_bsl" Тогда
		Возврат ПромптРефакторинга(Аргументы);
	ИначеЕсли ИмяПромпта = "code_review_bsl" Тогда
		Возврат ПромптРевью(Аргументы);
	ИначеЕсли ИмяПромпта = "query_generator" Тогда
		Возврат ПромптГенерацииЗапроса(Аргументы);
	ИначеЕсли ИмяПромпта = "error_explainer" Тогда
		Возврат ПромптОшибки(Аргументы);
	ИначеЕсли ИмяПромпта = "schema_to_form" Тогда
		Возврат ПромптФормы(Аргументы);
	КонецЕсли;
	ВызватьИсключение СтрШаблон("Неизвестный промпт: %1", ИмяПромпта);

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ПолеАргумента(Аргументы, Имя, ЗначениеПоУмолчанию = "")
	Если Аргументы = Неопределено Тогда Возврат ЗначениеПоУмолчанию; КонецЕсли;
	Если ТипЗнч(Аргументы) = Тип("Структура") И Аргументы.Свойство(Имя) Тогда
		Возврат СокрЛП(Строка(Аргументы[Имя]));
	КонецЕсли;
	Если ТипЗнч(Аргументы) = Тип("Соответствие") И Аргументы.Получить(Имя) <> Неопределено Тогда
		Возврат СокрЛП(Строка(Аргументы.Получить(Имя)));
	КонецЕсли;
	Возврат ЗначениеПоУмолчанию;
КонецФункции

Функция СтруктураПромпта(Описание, Сообщения)
	Результат = Новый Структура;
	Результат.Вставить("description", Описание);
	Результат.Вставить("messages", Сообщения);
	Возврат Результат;
КонецФункции

Функция ПромптРефакторинга(Аргументы)
	Код = ПолеАргумента(Аргументы, "code");
	Фокус = ПолеАргумента(Аргументы, "focus", "all");
	Если НЕ ЗначениеЗаполнено(Код) Тогда
		ВызватьИсключение "Параметр code обязателен для refactor_bsl";
	КонецЕсли;
	Системный = "Ты — senior 1С-разработчик. Все ответы на русском. Перед изменениями вызови get_metadata"
		+ " и validate_query, чтобы убедиться в существовании объектов и корректности запросов."
		+ " Соблюдай конвенции БСП и 1С:Стандарты. Запрещены ОбходРезультатаЗапроса.Прямой, точечная навигация"
		+ " по ссылкам внутри циклов, Выполнить()/Вычислить() кроме явных метапрограммных задач.";
	Пользователь = СтрШаблон(
		"Отрефактори следующий BSL-код с фокусом ""%1"". Сначала перечисли найденные антипаттерны (1С:Стандарт + краткое объяснение),"
		+ " потом выдай переработанный код целиком в одном блоке.%2```bsl%2%3%2```",
		Фокус, Символы.ПС, Код);
	Сообщения = Новый Массив;
	Сообщения.Добавить(mcp_Содержимое.СообщениеПромпта("user", Системный + Символы.ПС + Символы.ПС + Пользователь));
	Возврат СтруктураПромпта(СтрШаблон("Рефакторинг BSL (focus=%1)", Фокус), Сообщения);
КонецФункции

Функция ПромптРевью(Аргументы)
	Код = ПолеАргумента(Аргументы, "code");
	Строгость = ПолеАргумента(Аргументы, "strictness", "normal");
	Если НЕ ЗначениеЗаполнено(Код) Тогда
		ВызватьИсключение "Параметр code обязателен для code_review_bsl";
	КонецЕсли;
	Системный = "Ты — code reviewer уровня senior 1С. Перед review вызови get_metadata для всех упомянутых в коде"
		+ " объектов МД, чтобы убедиться в их существовании. Для каждой находки указывай severity (info/warning/error),"
		+ " номер 1С:Стандарта (если применимо), цитату строки и предложение фикса.";
	Пользователь = СтрШаблон(
		"Сделай code review с уровнем строгости ""%1"".%2```bsl%2%3%2```",
		Строгость, Символы.ПС, Код);
	Сообщения = Новый Массив;
	Сообщения.Добавить(mcp_Содержимое.СообщениеПромпта("user", Системный + Символы.ПС + Символы.ПС + Пользователь));
	Возврат СтруктураПромпта(СтрШаблон("Code review BSL (strictness=%1)", Строгость), Сообщения);
КонецФункции

Функция ПромптГенерацииЗапроса(Аргументы)
	Задача = ПолеАргумента(Аргументы, "task");
	Объекты = ПолеАргумента(Аргументы, "metadata_objects");
	Диалект = ПолеАргумента(Аргументы, "dialect", "1c_query");
	Если НЕ ЗначениеЗаполнено(Задача) Тогда
		ВызватьИсключение "Параметр task обязателен для query_generator";
	КонецЕсли;
	Системный = "Ты — 1С-эксперт по запросам. Алгоритм: 1) для каждого упомянутого объекта МД вызови get_metadata,"
		+ " 2) собери поля, 3) построй запрос (без точечной навигации в условиях соединений),"
		+ " 4) **обязательно** вызови validate_query на готовом тексте, 5) если ошибка — исправь и валидируй повторно (не более 3 итераций).";
	Пользователь = СтрШаблон(
		"Сгенерируй запрос %1.%2Бизнес-задача: %3.%2Объекты МД: %4",
		?(Диалект = "dcs", "для СКД (с пакетами и наборами)", "на языке 1С"),
		Символы.ПС, Задача,
		?(ЗначениеЗаполнено(Объекты), Объекты, "не указаны — определи сам через get_configuration/get_metadata"));
	Сообщения = Новый Массив;
	Сообщения.Добавить(mcp_Содержимое.СообщениеПромпта("user", Системный + Символы.ПС + Символы.ПС + Пользователь));
	Возврат СтруктураПромпта(СтрШаблон("Генерация %1 запроса", Диалект), Сообщения);
КонецФункции

Функция ПромптОшибки(Аргументы)
	ТекстОшибки = ПолеАргумента(Аргументы, "error_text");
	КодКонтекст = ПолеАргумента(Аргументы, "code_context");
	Если НЕ ЗначениеЗаполнено(ТекстОшибки) Тогда
		ВызватьИсключение "Параметр error_text обязателен для error_explainer";
	КонецЕсли;
	Системный = "Ты — эксперт по runtime-ошибкам 1С. Если ошибка касается метаданных — вызови get_metadata для"
		+ " упомянутых объектов. Если упоминается ЖР — get_event_log с filter по событию. Дай: 1) вероятная причина,"
		+ " 2) что воспроизводит, 3) минимальный фикс кодом (только нужные строки), 4) проверка после фикса.";
	КонтекстБлок = ?(ЗначениеЗаполнено(КодКонтекст),
		Символы.ПС + Символы.ПС + "Код-контекст:" + Символы.ПС + "```bsl" + Символы.ПС + КодКонтекст + Символы.ПС + "```",
		"");
	Пользователь = СтрШаблон(
		"Объясни и исправь ошибку 1С.%2Текст ошибки:%2```%2%3%2```%4",
		"", Символы.ПС, ТекстОшибки, КонтекстБлок);
	Сообщения = Новый Массив;
	Сообщения.Добавить(mcp_Содержимое.СообщениеПромпта("user", Системный + Символы.ПС + Символы.ПС + Пользователь));
	Возврат СтруктураПромпта("Анализ runtime-ошибки 1С", Сообщения);
КонецФункции

Функция ПромптФормы(Аргументы)
	ИмяОбъекта = ПолеАргумента(Аргументы, "object_name");
	ВидФормы = ПолеАргумента(Аргументы, "form_kind", "object");
	Если НЕ ЗначениеЗаполнено(ИмяОбъекта) Тогда
		ВызватьИсключение "Параметр object_name обязателен для schema_to_form";
	КонецЕсли;
	Системный = "Ты — генератор управляемых форм 1С. Алгоритм: 1) get_metadata(object_name, detail_level=full),"
		+ " 2) построй заготовку Form.xml: реквизит ""Объект"" + по группе на каждую ТЧ + поля для реквизитов из шапки,"
		+ " 3) построй заготовку Form.Module.bsl со стандартными обработчиками (ПриОткрытии, ПередЗакрытием).";
	Пользователь = СтрШаблон(
		"Создай заготовку формы %1 для %2. Выдай два блока: Form.xml и Form.Module.bsl. Соблюдай 1С:Стандарт по именованию"
		+ " (реквизиты с большой буквы, события через ""При…/Перед…"").",
		?(ВидФормы = "list", "списка", ?(ВидФормы = "choice", "выбора", "объекта")),
		ИмяОбъекта);
	Сообщения = Новый Массив;
	Сообщения.Добавить(mcp_Содержимое.СообщениеПромпта("user", Системный + Символы.ПС + Символы.ПС + Пользователь));
	Возврат СтруктураПромпта(СтрШаблон("Заготовка формы %1 для %2", ВидФормы, ИмяОбъекта), Сообщения);
КонецФункции

