//LN++ ManagerModule обработки LN_МСРИнструментМетаданные
// Tools:
//   - get_metadata          — структура объекта МД (реквизиты, ТЧ, измерения, ресурсы)
//   - get_configuration     — общая информация о конфигурации (имя, версия, поставщик, счётчики)
//   - describe_form         — реквизиты и элементы управляемой формы
//   - list_extensions       — список установленных расширений
//   - get_bsl_syntax_help   — поиск по справке встроенного языка (используется шаблон vendor)
//   - read_form_xml         — XML управляемой формы из дампа конфигурации на диске
//

Процедура ДобавитьИнструменты(Инструменты) Экспорт

	ДобавитьGetMetadata(Инструменты);
	ДобавитьGetConfiguration(Инструменты);
	ДобавитьDescribeForm(Инструменты);
	ДобавитьListExtensions(Инструменты);
	ДобавитьGetBslSyntaxHelp(Инструменты);
	ДобавитьReadFormXml(Инструменты);

КонецПроцедуры

Функция ВыполнитьИнструмент(ИмяИнструмента, Аргументы) Экспорт

	Если ИмяИнструмента = "get_metadata" Тогда
		Возврат ВыполнитьGetMetadata(Аргументы);
	ИначеЕсли ИмяИнструмента = "get_configuration" Тогда
		Возврат ВыполнитьGetConfiguration(Аргументы);
	ИначеЕсли ИмяИнструмента = "describe_form" Тогда
		Возврат ВыполнитьDescribeForm(Аргументы);
	ИначеЕсли ИмяИнструмента = "list_extensions" Тогда
		Возврат ВыполнитьListExtensions(Аргументы);
	ИначеЕсли ИмяИнструмента = "get_bsl_syntax_help" Тогда
		Возврат ВыполнитьGetBslSyntaxHelp(Аргументы);
	ИначеЕсли ИмяИнструмента = "read_form_xml" Тогда
		Возврат ВыполнитьReadFormXml(Аргументы);
	Иначе
		ВызватьИсключение "Неизвестный инструмент: " + ИмяИнструмента;
	КонецЕсли;

КонецФункции

#Область read_form_xml

Процедура ДобавитьReadFormXml(Инструменты)

	Параметры = Новый Массив;
	Параметры.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"object_name", "string",
		"Полное имя объекта МД (например ""Документ.РеализацияТоваровУслуг"")."
			+ " Допустимо ""Конфигурация"" для общих форм.", , Истина));
	Параметры.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"form_name", "string", "Имя формы (например ""ФормаДокумента"")", , Истина));
	Параметры.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"dump_path", "string",
		"Корневой путь дампа конфигурации (`DumpConfigToFiles` / `ibcmd infobase config export`)."
			+ " Если не задан — берётся из LN_МСРНастройки.config_dump_path.", , Ложь));
	Параметры.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"include_module", "boolean",
		"Дополнительно вернуть Form.Module.bsl. По умолчанию false.", Ложь));
	Параметры.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"max_chars", "number", "Лимит длины тела XML/BSL (по умолчанию 200000). 0 — без лимита.", 200000));

	mcp_Метаданные.ДобавитьИнструмент(Инструменты, "read_form_xml",
		"Читает Form.xml (и опционально Form.Module.bsl) управляемой формы напрямую с диска"
			+ " из дампа конфигурации. Дополняет describe_form реальной структурой элементов,"
			+ " доступ к которой невозможен из BSL в runtime через Метаданные.",
		mcp_Метаданные.СхемаПараметровИнструмента(Параметры));

КонецПроцедуры

Функция ВыполнитьReadFormXml(Аргументы)

	ИмяОбъекта = ?(Аргументы.Свойство("object_name"), СокрЛП(Строка(Аргументы.object_name)), "");
	ИмяФормы   = ?(Аргументы.Свойство("form_name"),   СокрЛП(Строка(Аргументы.form_name)),   "");
	Если Не ЗначениеЗаполнено(ИмяОбъекта) Или Не ЗначениеЗаполнено(ИмяФормы) Тогда
		ВызватьИсключение "object_name и form_name обязательны";
	КонецЕсли;
	ПутьДампа = ?(Аргументы.Свойство("dump_path"), СокрЛП(Строка(Аргументы.dump_path)), "");
	Если Не ЗначениеЗаполнено(ПутьДампа) Тогда
		ПутьДампа = LN_МСРКэш.ПолучитьНастройку("config_dump_path");
	КонецЕсли;
	Если Не ЗначениеЗаполнено(ПутьДампа) Тогда
		ВызватьИсключение "Не указан dump_path и не задана настройка config_dump_path";
	КонецЕсли;
	ВключатьМодуль = ?(Аргументы.Свойство("include_module"), Аргументы.include_module = Истина, Ложь);
	МаксСимволов   = ?(Аргументы.Свойство("max_chars"), Число(Аргументы.max_chars), 200000);

	КаталогФормы = ПолучитьПутьКПапкеФормы(ПутьДампа, ИмяОбъекта, ИмяФормы);
	ПутьXML      = ОбъединитьПути(КаталогФормы, "Ext\Form.xml");
	ПутьМодуля   = ОбъединитьПути(КаталогФормы, "Ext\Form\Module.bsl");
	Если Не НайтиФайлы(ПутьXML).Количество() Тогда
		// Альтернативный путь общей формы (без папки Forms/<Имя>)
		ПутьXML    = ОбъединитьПути(КаталогФормы, "Form.xml");
		ПутьМодуля = ОбъединитьПути(КаталогФормы, "Module.bsl");
	КонецЕсли;
	Если Не НайтиФайлы(ПутьXML).Количество() Тогда
		ВызватьИсключение СтрШаблон("Не удалось найти Form.xml по ожидаемым путям внутри %1", КаталогФормы);
	КонецЕсли;

	ТекстXML = ПрочитатьТекстовыйФайл(ПутьXML);
	Результат = Новый Структура;
	Результат.Вставить("object_name", ИмяОбъекта);
	Результат.Вставить("form_name", ИмяФормы);
	Результат.Вставить("xml_path", ПутьXML);
	Результат.Вставить("xml", LN_МСРКодирование.ОбрезатьСтроку(ТекстXML, МаксСимволов));
	Если ВключатьМодуль Тогда
		Если НайтиФайлы(ПутьМодуля).Количество() > 0 Тогда
			Результат.Вставить("module_path", ПутьМодуля);
			Результат.Вставить("module", LN_МСРКодирование.ОбрезатьСтроку(ПрочитатьТекстовыйФайл(ПутьМодуля), МаксСимволов));
		Иначе
			Результат.Вставить("module_path", ПутьМодуля);
			Результат.Вставить("module", Неопределено);
		КонецЕсли;
	КонецЕсли;
	Возврат Результат;

КонецФункции

Функция ПолучитьПутьКПапкеФормы(ПутьДампа, ИмяОбъекта, ИмяФормы)
	Части = СтрРазделить(ИмяОбъекта, ".", Ложь);
	Если Части.Количество() < 2 Тогда
		// Общая форма
		Возврат ОбъединитьПути(ОбъединитьПути(ПутьДампа, "CommonForms"), ИмяФормы);
	КонецЕсли;
	КатегорияРусская = СокрЛП(Части[0]);
	Имя              = СокрЛП(Части[1]);
	Категория        = АнглийскаяКатегорияФормы(КатегорияРусская);
	Если Не ЗначениеЗаполнено(Категория) Тогда
		ВызватьИсключение СтрШаблон("Неподдерживаемая категория объекта для form_xml: %1", КатегорияРусская);
	КонецЕсли;
	Возврат ОбъединитьПути(ОбъединитьПути(ОбъединитьПути(ОбъединитьПути(ПутьДампа, Категория), Имя), "Forms"), ИмяФормы);
КонецФункции

Функция АнглийскаяКатегорияФормы(Категория)
	С = Новый Соответствие;
	С.Вставить("Справочник", "Catalogs");
	С.Вставить("Документ", "Documents");
	С.Вставить("Отчет", "Reports");
	С.Вставить("Обработка", "DataProcessors");
	С.Вставить("РегистрСведений", "InformationRegisters");
	С.Вставить("РегистрНакопления", "AccumulationRegisters");
	С.Вставить("РегистрБухгалтерии", "AccountingRegisters");
	С.Вставить("РегистрРасчета", "CalculationRegisters");
	С.Вставить("ПланВидовХарактеристик", "ChartsOfCharacteristicTypes");
	С.Вставить("ПланСчетов", "ChartsOfAccounts");
	С.Вставить("ПланВидовРасчета", "ChartsOfCalculationTypes");
	С.Вставить("БизнесПроцесс", "BusinessProcesses");
	С.Вставить("Задача", "Tasks");
	С.Вставить("ПланОбмена", "ExchangePlans");
	С.Вставить("Перечисление", "Enums");
	Возврат ?(С.Получить(Категория) = Неопределено, "", С.Получить(Категория));
КонецФункции

Функция ОбъединитьПути(А, Б)
	А = СтрЗаменить(А, "/", "\");
	Если Прав(А, 1) <> "\" Тогда А = А + "\"; КонецЕсли;
	Возврат А + СтрЗаменить(Б, "/", "\");
КонецФункции

Функция ПрочитатьТекстовыйФайл(Путь)
	Чтение = Новый ЧтениеТекста(Путь, КодировкаТекста.UTF8);
	Возврат Чтение.Прочитать();
КонецФункции

#КонецОбласти

#Область get_metadata

Процедура ДобавитьGetMetadata(Инструменты)

	Параметры = Новый Массив;
	Параметры.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"object_name", "string", "Полное имя объекта МД (например ""Справочник.Контрагенты"")", , Истина));
	Параметры.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"detail_level", "string", "brief | normal | full (по умолчанию normal)", "normal", Ложь,
		"brief,normal,full"));

	mcp_Метаданные.ДобавитьИнструмент(
		Инструменты,
		"get_metadata",
		"Возвращает структуру объекта метаданных: реквизиты, табличные части, измерения, ресурсы."
			+ " Уровни: brief — только имена, normal — типы и синонимы, full — все свойства.",
		mcp_Метаданные.СхемаПараметровИнструмента(Параметры));

КонецПроцедуры

Функция ВыполнитьGetMetadata(Аргументы)

	ИмяОбъекта = ?(Аргументы.Свойство("object_name"), Аргументы.object_name, "");
	Если НЕ ЗначениеЗаполнено(ИмяОбъекта) Тогда
		ВызватьИсключение "Параметр object_name обязателен";
	КонецЕсли;
	УровеньДетализации = ?(Аргументы.Свойство("detail_level"), Аргументы.detail_level, "normal");

	КэшПопадание = LN_МСРКэш.Получить("get_metadata", Аргументы);
	Если КэшПопадание <> Неопределено Тогда
		Возврат КэшПопадание;
	КонецЕсли;

	МД = Метаданные.НайтиПоПолномуИмени(ИмяОбъекта);
	Если МД = Неопределено Тогда
		ВызватьИсключение "Объект метаданных не найден: " + ИмяОбъекта;
	КонецЕсли;

	Результат = Новый Структура;
	Результат.Вставить("name",      МД.Имя);
	Результат.Вставить("full_name", МД.ПолноеИмя());
	Результат.Вставить("synonym",   МД.Синоним);
	Результат.Вставить("comment",   МД.Комментарий);

	Если УровеньДетализации = "brief" Тогда
		LN_МСРКэш.Сохранить("get_metadata", Аргументы, Результат, 3600);
		Возврат Результат;
	КонецЕсли;

	ЗаполнитьСостав(МД, Результат, УровеньДетализации = "full");

	LN_МСРКэш.Сохранить("get_metadata", Аргументы, Результат, 3600);
	Возврат Результат;

КонецФункции

Процедура ЗаполнитьСостав(МД, Результат, Полный)

	// Реквизиты
	Если ЭтоСвойство(МД, "Реквизиты") Тогда
		Реквизиты = Новый Массив;
		Для Каждого Рек Из МД.Реквизиты Цикл
			Реквизиты.Добавить(ОписаниеПоляМД(Рек, Полный));
		КонецЦикла;
		Результат.Вставить("attributes", Реквизиты);
	КонецЕсли;
	// Стандартные реквизиты
	Если ЭтоСвойство(МД, "СтандартныеРеквизиты") Тогда
		СтандРек = Новый Массив;
		Для Каждого Рек Из МД.СтандартныеРеквизиты Цикл
			СтандРек.Добавить(Новый Структура("name, synonym", Рек.Имя, Рек.Синоним));
		КонецЦикла;
		Результат.Вставить("standard_attributes", СтандРек);
	КонецЕсли;
	// Табличные части
	Если ЭтоСвойство(МД, "ТабличныеЧасти") Тогда
		ТЧ = Новый Массив;
		Для Каждого Т Из МД.ТабличныеЧасти Цикл
			Реквизиты = Новый Массив;
			Для Каждого Рек Из Т.Реквизиты Цикл
				Реквизиты.Добавить(ОписаниеПоляМД(Рек, Полный));
			КонецЦикла;
			ТЧ.Добавить(Новый Структура("name, synonym, attributes", Т.Имя, Т.Синоним, Реквизиты));
		КонецЦикла;
		Результат.Вставить("tabular_sections", ТЧ);
	КонецЕсли;
	// Измерения (регистры)
	Если ЭтоСвойство(МД, "Измерения") Тогда
		Изм = Новый Массив;
		Для Каждого Измерение Из МД.Измерения Цикл
			Изм.Добавить(ОписаниеПоляМД(Измерение, Полный));
		КонецЦикла;
		Результат.Вставить("dimensions", Изм);
	КонецЕсли;
	// Ресурсы (регистры)
	Если ЭтоСвойство(МД, "Ресурсы") Тогда
		Рес = Новый Массив;
		Для Каждого Ресурс Из МД.Ресурсы Цикл
			Рес.Добавить(ОписаниеПоляМД(Ресурс, Полный));
		КонецЦикла;
		Результат.Вставить("resources", Рес);
	КонецЕсли;
	// Формы
	Если ЭтоСвойство(МД, "Формы") Тогда
		Формы = Новый Массив;
		Для Каждого Ф Из МД.Формы Цикл
			Формы.Добавить(Ф.Имя);
		КонецЦикла;
		Результат.Вставить("forms", Формы);
	КонецЕсли;

КонецПроцедуры

Функция ОписаниеПоляМД(Поле, Полный)

	Опис = Новый Структура;
	Опис.Вставить("name", Поле.Имя);
	Опис.Вставить("synonym", Поле.Синоним);
	Опис.Вставить("type", ОписаниеТипа(Поле.Тип));
	Если Полный Тогда
		Опис.Вставить("comment", Поле.Комментарий);
		Если ЭтоСвойство(Поле, "Индексирование") Тогда
			Опис.Вставить("indexing", Строка(Поле.Индексирование));
		КонецЕсли;
		Если ЭтоСвойство(Поле, "ПолнотекстовыйПоиск") Тогда
			Опис.Вставить("full_text_search", Строка(Поле.ПолнотекстовыйПоиск));
		КонецЕсли;
	КонецЕсли;
	Возврат Опис;

КонецФункции

Функция ОписаниеТипа(ОписаниеТипов)

	Если ОписаниеТипов = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	Типы = Новый Массив;
	Для Каждого Т Из ОписаниеТипов.Типы() Цикл
		Типы.Добавить(Строка(Т));
	КонецЦикла;
	Возврат СтрСоединить(Типы, " | ");

КонецФункции

Функция ЭтоСвойство(Объект, ИмяСвойства)

	Попытка
		Значение = Объект[ИмяСвойства];
		Возврат Истина;
	Исключение
		Возврат Ложь;
	КонецПопытки;

КонецФункции

Функция ЗначениеСвойстваОбъекта(Объект, ИмяСвойства)

	Попытка
		Возврат Объект[ИмяСвойства];
	Исключение
		Возврат Неопределено;
	КонецПопытки;

КонецФункции

#КонецОбласти

#Область get_configuration

Процедура ДобавитьGetConfiguration(Инструменты)

	mcp_Метаданные.ДобавитьИнструмент(
		Инструменты,
		"get_configuration",
		"Возвращает структуру с базовой информацией о конфигурации: имя, синоним, версия, поставщик,"
			+ " режим совместимости, режим управляемого приложения, статистика по типам объектов.",
		mcp_Метаданные.СхемаПараметровИнструмента(Новый Массив));

КонецПроцедуры

Функция ВыполнитьGetConfiguration(Аргументы)

	КэшПопадание = LN_МСРКэш.Получить("get_configuration", Аргументы);
	Если КэшПопадание <> Неопределено Тогда
		Возврат КэшПопадание;
	КонецЕсли;

	Результат = Новый Структура;
	Результат.Вставить("name", Метаданные.Имя);
	Результат.Вставить("synonym", Метаданные.Синоним);
	Результат.Вставить("version", Метаданные.Версия);
	Результат.Вставить("vendor", Метаданные.Поставщик);
	Результат.Вставить("comment", Метаданные.Комментарий);
	Результат.Вставить("compatibility_mode", Строка(Метаданные.РежимСовместимости));
	РежимЗапуска = ЗначениеСвойстваОбъекта(Метаданные, "ОсновнойРежимЗапуска");
	Результат.Вставить("default_run_mode", ?(РежимЗапуска = Неопределено, "", Строка(РежимЗапуска)));
	Результат.Вставить("script_variant", Строка(Метаданные.ВариантВстроенногоЯзыка));

	Счётчики = Новый Структура;
	Счётчики.Вставить("catalogs", Метаданные.Справочники.Количество());
	Счётчики.Вставить("documents", Метаданные.Документы.Количество());
	Счётчики.Вставить("information_registers", Метаданные.РегистрыСведений.Количество());
	Счётчики.Вставить("accumulation_registers", Метаданные.РегистрыНакопления.Количество());
	Счётчики.Вставить("accounting_registers", Метаданные.РегистрыБухгалтерии.Количество());
	Счётчики.Вставить("common_modules", Метаданные.ОбщиеМодули.Количество());
	Счётчики.Вставить("enums", Метаданные.Перечисления.Количество());
	Счётчики.Вставить("reports", Метаданные.Отчеты.Количество());
	Счётчики.Вставить("data_processors", Метаданные.Обработки.Количество());
	Счётчики.Вставить("http_services", Метаданные.HTTPСервисы.Количество());
	Счётчики.Вставить("subsystems", Метаданные.Подсистемы.Количество());
	Счётчики.Вставить("roles", Метаданные.Роли.Количество());
	Результат.Вставить("counters", Счётчики);

	LN_МСРКэш.Сохранить("get_configuration", Аргументы, Результат, 7200);
	Возврат Результат;

КонецФункции

#КонецОбласти

#Область describe_form

Процедура ДобавитьDescribeForm(Инструменты)

	Параметры = Новый Массив;
	Параметры.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"object_name", "string", "Полное имя объекта (например ""Справочник.Контрагенты"")", , Истина));
	Параметры.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"form_name", "string", "Имя формы. Если не указано — берётся форма списка / форма по умолчанию.", , Ложь));

	mcp_Метаданные.ДобавитьИнструмент(
		Инструменты,
		"describe_form",
		"Возвращает структуру управляемой формы: реквизиты, команды, схему. На уровне метаданных"
			+ " (без открытия формы пользователем) доступны имя, синоним и список форм.",
		mcp_Метаданные.СхемаПараметровИнструмента(Параметры));

КонецПроцедуры

Функция ВыполнитьDescribeForm(Аргументы)

	ИмяОбъекта = ?(Аргументы.Свойство("object_name"), Аргументы.object_name, "");
	Если НЕ ЗначениеЗаполнено(ИмяОбъекта) Тогда
		ВызватьИсключение "Параметр object_name обязателен";
	КонецЕсли;
	МД = Метаданные.НайтиПоПолномуИмени(ИмяОбъекта);
	Если МД = Неопределено Тогда
		ВызватьИсключение "Объект метаданных не найден: " + ИмяОбъекта;
	КонецЕсли;

	ИмяФормы = ?(Аргументы.Свойство("form_name"), Аргументы.form_name, "");
	Форма = Неопределено;
	Если ЗначениеЗаполнено(ИмяФормы) Тогда
		Форма = МД.Формы.Найти(ИмяФормы);
	Иначе
		// Пробуем стандартные формы по умолчанию: списка, объекта, группы, выбора
		Для Каждого ИмяСтандартнойФормы Из СтрРазделить(
			"ФормаСписка,ФормаОбъекта,ФормаГруппы,ФормаВыбора,ФормаДокумента,ФормаВыбораГруппы", ",", Ложь) Цикл
			Если ЭтоСвойство(МД, ИмяСтандартнойФормы) И МД[ИмяСтандартнойФормы] <> Неопределено Тогда
				Форма = МД[ИмяСтандартнойФормы];
				Прервать;
			КонецЕсли;
		КонецЦикла;
		Если Форма = Неопределено И МД.Формы.Количество() > 0 Тогда
			Форма = МД.Формы[0];
		КонецЕсли;
	КонецЕсли;

	Если Форма = Неопределено Тогда
		ВызватьИсключение "Форма не найдена: " + ?(ЗначениеЗаполнено(ИмяФормы), ИмяФормы, "(форма по умолчанию)");
	КонецЕсли;

	Результат = Новый Структура;
	Результат.Вставить("object",         МД.ПолноеИмя());
	Результат.Вставить("form_name",      Форма.Имя);
	Результат.Вставить("form_synonym",   Форма.Синоним);
	Результат.Вставить("form_full_name", Форма.ПолноеИмя());
	Результат.Вставить("form_comment",   Форма.Комментарий);

	// Список всех форм объекта
	ВсеФормы = Новый Массив;
	Для Каждого Ф Из МД.Формы Цикл
		ВсеФормы.Добавить(Новый Структура("name, synonym, full_name",
			Ф.Имя, Ф.Синоним, Ф.ПолноеИмя()));
	КонецЦикла;
	Результат.Вставить("all_forms", ВсеФормы);

	// Реквизиты объекта (источник данных формы)
	Атрибуты = Новый Массив;
	Если ЭтоСвойство(МД, "Реквизиты") И МД.Реквизиты <> Неопределено Тогда
		Для Каждого Рек Из МД.Реквизиты Цикл
			Атрибуты.Добавить(ОписаниеРеквизита(Рек));
		КонецЦикла;
	КонецЕсли;
	Результат.Вставить("object_attributes", Атрибуты);

	// Стандартные реквизиты (Код, Наименование, Дата, Номер, Ссылка, ...)
	СтандартныеРеквизиты = Новый Массив;
	Попытка
		Для Каждого СтдРек Из МД.СтандартныеРеквизиты Цикл
			СтандартныеРеквизиты.Добавить(ОписаниеРеквизита(СтдРек));
		КонецЦикла;
	Исключение
	КонецПопытки;
	Результат.Вставить("standard_attributes", СтандартныеРеквизиты);

	// Табличные части
	ТЧ = Новый Массив;
	Если ЭтоСвойство(МД, "ТабличныеЧасти") И МД.ТабличныеЧасти <> Неопределено Тогда
		Для Каждого ТабЧасть Из МД.ТабличныеЧасти Цикл
			Колонки = Новый Массив;
			Для Каждого Рек Из ТабЧасть.Реквизиты Цикл
				Колонки.Добавить(ОписаниеРеквизита(Рек));
			КонецЦикла;
			ТЧ.Добавить(Новый Структура("name, synonym, columns",
				ТабЧасть.Имя, ТабЧасть.Синоним, Колонки));
		КонецЦикла;
	КонецЕсли;
	Результат.Вставить("object_tabular_sections", ТЧ);

	// Команды объекта (если есть)
	Команды = Новый Массив;
	Попытка
		Для Каждого Кмд Из МД.Команды Цикл
			Команды.Добавить(Новый Структура("name, synonym", Кмд.Имя, Кмд.Синоним));
		КонецЦикла;
	Исключение
	КонецПопытки;
	Результат.Вставить("object_commands", Команды);

	// Честное предупреждение: внутренний состав элементов формы и её собственные реквизиты
	// (поле "Реквизиты" формы, "Элементы", "Команды") в платформе доступны ТОЛЬКО в runtime —
	// после открытия формы на клиенте через ПолучитьФорму()/ОткрытьФорму(). HTTP-сервис не имеет
	// клиентской сессии, поэтому здесь возвращается описание из метаданных + структура объекта-источника.
	Результат.Вставить("note",
		"Состав реквизитов/элементов/команд самой управляемой формы доступен только в клиентской runtime-сессии"
		+ " (через ПолучитьФорму). HTTP-сервис возвращает: имя/синоним формы, список всех форм объекта"
		+ " и полную структуру объекта-источника (реквизиты, стандартные реквизиты, табличные части, команды).");
	Возврат Результат;

КонецФункции

Функция ОписаниеРеквизита(Рек)
	Описание = Новый Структура;
	Описание.Вставить("name",    Рек.Имя);
	Описание.Вставить("synonym", ?(ЭтоСвойство(Рек, "Синоним"), Рек.Синоним, ""));
	Типы = Новый Массив;
	Попытка
		Для Каждого Т Из Рек.Тип.Типы() Цикл
			Типы.Добавить(Строка(Т));
		КонецЦикла;
	Исключение
	КонецПопытки;
	Описание.Вставить("types", Типы);
	Возврат Описание;
КонецФункции

#КонецОбласти

#Область list_extensions

Процедура ДобавитьListExtensions(Инструменты)

	mcp_Метаданные.ДобавитьИнструмент(
		Инструменты,
		"list_extensions",
		"Возвращает массив установленных в инфобазе расширений с их именами, версиями, "
			+ "поставщиками и статусом активности.",
		mcp_Метаданные.СхемаПараметровИнструмента(Новый Массив));

КонецПроцедуры

Функция ВыполнитьListExtensions(Аргументы)

	Список = Новый Массив;
	Для Каждого Расширение Из РасширенияКонфигурации.Получить() Цикл
		Запись = Новый Структура;
		Запись.Вставить("name",         Расширение.Имя);
		Запись.Вставить("synonym",      Расширение.Синоним);
		Запись.Вставить("version",      Расширение.Версия);
		Запись.Вставить("active",       Расширение.Активно);
		Запись.Вставить("safe_mode",    Расширение.БезопасныйРежим);
		Запись.Вставить("uuid",         Строка(Расширение.УникальныйИдентификатор));
		Запись.Вставить("purpose",      Строка(Расширение.Назначение));
		Список.Добавить(Запись);
	КонецЦикла;
	Возврат Список;

КонецФункции

#КонецОбласти

#Область get_bsl_syntax_help

Процедура ДобавитьGetBslSyntaxHelp(Инструменты)

	Параметры = Новый Массив;
	Параметры.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"topic", "string", "Имя метода / типа для поиска в справке", , Истина));

	mcp_Метаданные.ДобавитьИнструмент(
		Инструменты,
		"get_bsl_syntax_help",
		"Поиск по описанию синтаксиса встроенного языка (vendor template syntax_1c)."
			+ " Возвращает все блоки справки, содержащие topic в заголовке.",
		mcp_Метаданные.СхемаПараметровИнструмента(Параметры));

КонецПроцедуры

Функция ВыполнитьGetBslSyntaxHelp(Аргументы)

	Тема = ?(Аргументы.Свойство("topic"), Аргументы.topic, "");
	Если НЕ ЗначениеЗаполнено(Тема) Тогда
		ВызватьИсключение "Параметр topic обязателен";
	КонецЕсли;

	Попытка
		Макет = Обработки.mcp_РесурсОписаниеСинтаксисаВстроенногоЯзыка.ПолучитьМакет("syntax_1c");
	Исключение
		ВызватьИсключение "Шаблон описания синтаксиса не доступен: " + ОписаниеОшибки();
	КонецПопытки;

	ТекстПолный = Макет.ПолучитьТекст();
	ТемаВРег = НРег(Тема);

	Найденные = Новый Массив;
	Блоки = СтрРазделить(ТекстПолный, "" + Символы.ПС + Символы.ПС, Истина);
	Для Каждого Блок Из Блоки Цикл
		Если СтрНайти(НРег(Блок), ТемаВРег) > 0 Тогда
			Найденные.Добавить(Блок);
			Если Найденные.Количество() >= 5 Тогда
				Прервать;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;

	Результат = Новый Структура;
	Результат.Вставить("topic", Тема);
	Результат.Вставить("matches", Найденные);
	Результат.Вставить("matches_count", Найденные.Количество());
	Возврат Результат;

КонецФункции

#КонецОбласти
