//LN++ ManagerModule контейнера ресурсов LN_МСРРесурсыПроекта.
// Универсальный контейнер для собственных ресурсов проекта. Адреса:
//   ln-mcp://ln/common-module/<Имя>       — исходник общего модуля основной конфигурации
//   ln-mcp://ln/role/<Имя>                — XML-описание прав роли
//   ln-mcp://ln/dcs/<ИмяОтчёта>           — основная схема компоновки данных отчёта
//   ln-mcp://ln/mxl/<Объект>/<Макет>      — содержимое макета MXL (получаемый табличный документ)
//
// Реализация:
//   - ДобавитьРесурсы строит сводный индекс через единый ресурс «ln-mcp://ln/_index.json»;
//   - конкретные адреса добавляются «по требованию» (lazy) — список конкретных объектов
//     добавляется в индекс (см. /resources/list), а ПрочитатьРесурс маршрутизирует по префиксу.
//   - Реализация безопасная для read-only ManagerModule: исходники модулей читаются через
//     ПолучитьИсходныйКод(), макеты — через ПолучитьМакет().

#Область ПрограммныйИнтерфейс

Процедура ДобавитьРесурсы(ТаблицаРесурсов) Экспорт

	mcp_Метаданные.ДобавитьРесурс(
		ТаблицаРесурсов,
		"ln-mcp://ln/_index.json",
		"ln_resources_index",
		"Индекс всех собственных ресурсов проекта (общие модули, роли, СКД, MXL) одним JSON-документом");

	// В resources/list — только точки входа. Конкретные адреса (common-module, role, dcs, mxl)
	// доступны через resources/read по URI из индекса; маршрутизация — в ПрочитатьРесурс.
	mcp_Метаданные.ДобавитьРесурс(ТаблицаРесурсов,
		"ln-mcp://ln/mxl/", "mxl:catalog",
		"Маршрутный адрес для MXL-макетов конкретных объектов: ln-mcp://ln/mxl/<Тип>.<Имя>/<Макет>."
			+ " Полный список — в ln-mcp://ln/_index.json (поле mxl_object_templates).");

КонецПроцедуры

Функция ПрочитатьРесурс(Адрес) Экспорт

	Если Адрес = "ln-mcp://ln/_index.json" Тогда
		Возврат ПостроитьИндексJSON();
	КонецЕсли;

	Если СтрНачинаетсяС(Адрес, "ln-mcp://ln/common-module/") Тогда
		ИмяМодуля = Сред(Адрес, СтрДлина("ln-mcp://ln/common-module/") + 1);
		Возврат ПрочитатьОбщийМодуль(ИмяМодуля);
	КонецЕсли;

	Если СтрНачинаетсяС(Адрес, "ln-mcp://ln/role/") Тогда
		ИмяРоли = Сред(Адрес, СтрДлина("ln-mcp://ln/role/") + 1);
		Возврат ПрочитатьРоль(ИмяРоли);
	КонецЕсли;

	Если СтрНачинаетсяС(Адрес, "ln-mcp://ln/dcs/") Тогда
		ИмяОтчёта = Сред(Адрес, СтрДлина("ln-mcp://ln/dcs/") + 1);
		Возврат ПрочитатьСКД(ИмяОтчёта);
	КонецЕсли;

	Если СтрНачинаетсяС(Адрес, "ln-mcp://ln/mxl/") Тогда
		ХвостАдреса = Сред(Адрес, СтрДлина("ln-mcp://ln/mxl/") + 1);
		Возврат ПрочитатьMXL(ХвостАдреса);
	КонецЕсли;

	ВызватьИсключение СтрШаблон("Неизвестный адрес ресурса LN: %1", Адрес);

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ПостроитьИндексJSON()

	Индекс = Новый Структура;

	МассивОМ = Новый Массив;
	Для Каждого ОМ Из Метаданные.ОбщиеМодули Цикл
		МассивОМ.Добавить(Новый Структура("name, address",
			ОМ.Имя, "ln-mcp://ln/common-module/" + ОМ.Имя));
	КонецЦикла;
	Индекс.Вставить("common_modules", МассивОМ);

	МассивРолей = Новый Массив;
	Для Каждого Роль Из Метаданные.Роли Цикл
		МассивРолей.Добавить(Новый Структура("name, address",
			Роль.Имя, "ln-mcp://ln/role/" + Роль.Имя));
	КонецЦикла;
	Индекс.Вставить("roles", МассивРолей);

	МассивСКД = Новый Массив;
	Для Каждого Отчёт Из Метаданные.Отчеты Цикл
		Если ОсновнаяСхемаОтчета(Отчёт) <> Неопределено Тогда
			МассивСКД.Добавить(Новый Структура("name, address",
				Отчёт.Имя, "ln-mcp://ln/dcs/" + Отчёт.Имя));
		КонецЕсли;
	КонецЦикла;
	Индекс.Вставить("dcs_schemas", МассивСКД);

	МассивMXL = Новый Массив;
	Для Каждого Макет Из Метаданные.ОбщиеМакеты Цикл
		Если Макет.ТипМакета = Метаданные.СвойстваОбъектов.ТипМакета.ТабличныйДокумент Тогда
			МассивMXL.Добавить(Новый Структура("name, address",
				Макет.Имя, "ln-mcp://ln/mxl/common/" + Макет.Имя));
		КонецЕсли;
	КонецЦикла;
	Индекс.Вставить("mxl_templates", МассивMXL);

	// MXL внутри объектов МД
	МассивMXLОбъектов = Новый Массив;
	Для Каждого Колл Из КоллекцииСМакетами() Цикл
		Для Каждого МД Из Колл Цикл
			МакетыКолл = МакетыОбъекта(МД);
			Для Каждого Макет Из МакетыКолл Цикл
				Если Макет.ТипМакета = Метаданные.СвойстваОбъектов.ТипМакета.ТабличныйДокумент Тогда
					МассивMXLОбъектов.Добавить(Новый Структура("owner, template, address",
						МД.ПолноеИмя(),
						Макет.Имя,
						"ln-mcp://ln/mxl/" + МД.ПолноеИмя() + "/" + Макет.Имя));
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;
	Индекс.Вставить("mxl_object_templates", МассивMXLОбъектов);

	Возврат LN_МСРКодирование.ЗначениеВJSON(Индекс);

КонецФункции

// Коллекции, у объектов которых платформенно есть свойство Макеты.
Функция КоллекцииСМакетами()
	К = Новый Массив;
	К.Добавить(Метаданные.Справочники);
	К.Добавить(Метаданные.Документы);
	К.Добавить(Метаданные.Отчеты);
	К.Добавить(Метаданные.Обработки);
	К.Добавить(Метаданные.ПланыВидовХарактеристик);
	К.Добавить(Метаданные.ПланыСчетов);
	К.Добавить(Метаданные.ПланыВидовРасчета);
	К.Добавить(Метаданные.ПланыОбмена);
	К.Добавить(Метаданные.БизнесПроцессы);
	К.Добавить(Метаданные.Задачи);
	К.Добавить(Метаданные.РегистрыСведений);
	К.Добавить(Метаданные.РегистрыНакопления);
	К.Добавить(Метаданные.РегистрыБухгалтерии);
	К.Добавить(Метаданные.РегистрыРасчета);
	Возврат К;
КонецФункции

Функция МакетыОбъекта(МД)
	Попытка
		Возврат МД.Макеты;
	Исключение
		Возврат Новый Массив;
	КонецПопытки;
КонецФункции

Функция ПрочитатьОбщийМодуль(Имя)

	ОМ = Метаданные.ОбщиеМодули.Найти(Имя);
	Если ОМ = Неопределено Тогда
		ВызватьИсключение СтрШаблон("Общий модуль %1 не найден", Имя);
	КонецЕсли;
	Попытка
		Возврат ОМ.ПолучитьИсходныйКод();
	Исключение
		ВызватьИсключение СтрШаблон("Не удалось получить исходный код общего модуля %1: %2",
			Имя, ОписаниеОшибки());
	КонецПопытки;

КонецФункции

Функция ПрочитатьРоль(Имя)

	Роль = Метаданные.Роли.Найти(Имя);
	Если Роль = Неопределено Тогда
		ВызватьИсключение СтрШаблон("Роль %1 не найдена", Имя);
	КонецЕсли;

	// Платформенного публичного API «получить XML роли» нет — собираем структуру вручную.
	Описание = Новый Структура;
	Описание.Вставить("name", Роль.Имя);
	Описание.Вставить("synonym", Роль.Синоним.Получить("ru"));
	Описание.Вставить("comment", Роль.Комментарий);
	Описание.Вставить("set_for_attributes_by_default", Роль.УстановкаПравДляНовыхОбъектов);
	Описание.Вставить("set_for_attributes_by_default_standard_data",
		Роль.УстановкаПравДляРеквизитовИТабличныхЧастейПоУмолчанию);
	Описание.Вставить("independent_subordinate_rights",
		Роль.НезависимыеПраваПодчиненныхОбъектов);

	Объекты = Новый Массив;
	Для Каждого МДОб Из Метаданные.ОбщиеРеквизиты Цикл
		ДобавитьПраваОбъекта(Роль, МДОб, Объекты);
	КонецЦикла;
	Для Каждого Колл Из ИтерируемыеКоллекцииМетаданных() Цикл
		Для Каждого МДОб Из Колл Цикл
			ДобавитьПраваОбъекта(Роль, МДОб, Объекты);
		КонецЦикла;
	КонецЦикла;
	Описание.Вставить("rights", Объекты);

	Возврат LN_МСРКодирование.ЗначениеВJSON(Описание);

КонецФункции

Функция ИтерируемыеКоллекцииМетаданных()
	М = Новый Массив;
	М.Добавить(Метаданные.Константы);
	М.Добавить(Метаданные.Справочники);
	М.Добавить(Метаданные.Документы);
	М.Добавить(Метаданные.ЖурналыДокументов);
	М.Добавить(Метаданные.Перечисления);
	М.Добавить(Метаданные.Отчеты);
	М.Добавить(Метаданные.Обработки);
	М.Добавить(Метаданные.ПланыВидовХарактеристик);
	М.Добавить(Метаданные.ПланыСчетов);
	М.Добавить(Метаданные.ПланыВидовРасчета);
	М.Добавить(Метаданные.РегистрыСведений);
	М.Добавить(Метаданные.РегистрыНакопления);
	М.Добавить(Метаданные.РегистрыБухгалтерии);
	М.Добавить(Метаданные.РегистрыРасчета);
	М.Добавить(Метаданные.БизнесПроцессы);
	М.Добавить(Метаданные.Задачи);
	М.Добавить(Метаданные.ОбщиеМодули);
	М.Добавить(Метаданные.HTTPСервисы);
	М.Добавить(Метаданные.WebСервисы);
	Возврат М;
КонецФункции

Процедура ДобавитьПраваОбъекта(Роль, МДОб, Объекты)

	Попытка
		Права = Роль.Права.НайтиПраваПоОбъекту(МДОб);
	Исключение
		Возврат;
	КонецПопытки;
	Если Права = Неопределено Тогда
		Возврат;
	КонецЕсли;
	СписокПрав = Новый Массив;
	Для Каждого Право Из Права Цикл
		СписокПрав.Добавить(Право.Имя);
	КонецЦикла;
	Если СписокПрав.Количество() > 0 Тогда
		Объекты.Добавить(Новый Структура("object, rights", МДОб.ПолноеИмя(), СписокПрав));
	КонецЕсли;

КонецПроцедуры

Функция ПрочитатьСКД(ИмяОтчёта)

	Отчёт = Метаданные.Отчеты.Найти(ИмяОтчёта);
	СхемаОтчета = ОсновнаяСхемаОтчета(Отчёт);
	Если Отчёт = Неопределено Или СхемаОтчета = Неопределено Тогда
		ВызватьИсключение СтрШаблон("Основная СКД для отчёта %1 не найдена", ИмяОтчёта);
	КонецЕсли;
	Попытка
		СКД = Отчеты[ИмяОтчёта].ПолучитьМакет(СхемаОтчета.Имя);
		ЗаписьXML = Новый ЗаписьXML;
		ЗаписьXML.УстановитьСтроку();
		СериализаторXDTO.ЗаписатьXML(ЗаписьXML, СКД);
		Возврат ЗаписьXML.Закрыть();
	Исключение
		ВызватьИсключение СтрШаблон("Не удалось сериализовать СКД отчёта %1: %2",
			ИмяОтчёта, ОписаниеОшибки());
	КонецПопытки;

КонецФункции

Функция ПрочитатьMXL(ХвостАдреса)

	// 1) Общие макеты: common/<Имя>
	Если СтрНачинаетсяС(ХвостАдреса, "common/") Тогда
		ИмяМакета = Сред(ХвостАдреса, СтрДлина("common/") + 1);
		МДМакет = Метаданные.ОбщиеМакеты.Найти(ИмяМакета);
		Если МДМакет = Неопределено Тогда
			ВызватьИсключение СтрШаблон("Общий макет %1 не найден", ИмяМакета);
		КонецЕсли;
		Возврат СериализоватьТабличныйДокумент(ПолучитьОбщийМакет(ИмяМакета), ИмяМакета);
	КонецЕсли;

	// 2) Макеты конкретных объектов: <Тип>.<Имя>/<ИмяМакета>
	//    Например: Документ.РеализацияТоваровУслуг/ПФ_MXL_Накладная
	Поз = СтрНайти(ХвостАдреса, "/");
	Если Поз = 0 Тогда
		ВызватьИсключение СтрШаблон("Некорректный адрес MXL-ресурса: %1 (ожидался <Тип>.<Имя>/<Макет>)", ХвостАдреса);
	КонецЕсли;
	ПолноеИмяОбъекта = Лев(ХвостАдреса, Поз - 1);
	ИмяМакета = Сред(ХвостАдреса, Поз + 1);

	МДОбъекта = Метаданные.НайтиПоПолномуИмени(ПолноеИмяОбъекта);
	Если МДОбъекта = Неопределено Тогда
		ВызватьИсключение СтрШаблон("Объект МД %1 не найден", ПолноеИмяОбъекта);
	КонецЕсли;

	КоллекцияМенеджера = МенеджерКоллекцииПоОбъекту(МДОбъекта);
	Если КоллекцияМенеджера = Неопределено Тогда
		ВызватьИсключение СтрШаблон("У объекта %1 нет менеджера с макетами", ПолноеИмяОбъекта);
	КонецЕсли;

	Попытка
		МенеджерОбъекта = КоллекцияМенеджера[МДОбъекта.Имя];
		ТД = МенеджерОбъекта.ПолучитьМакет(ИмяМакета);
		Возврат СериализоватьТабличныйДокумент(ТД, ПолноеИмяОбъекта + "." + ИмяМакета);
	Исключение
		ВызватьИсключение СтрШаблон("Не удалось получить макет %1.%2: %3",
			ПолноеИмяОбъекта, ИмяМакета, ОписаниеОшибки());
	КонецПопытки;

КонецФункции

Функция СериализоватьТабличныйДокумент(ТД, ИмяДляОшибки)
	Попытка
		Если ТипЗнч(ТД) = Тип("ТабличныйДокумент") Тогда
			ЗаписьXML = Новый ЗаписьXML;
			ЗаписьXML.УстановитьСтроку();
			СериализаторXDTO.ЗаписатьXML(ЗаписьXML, ТД);
			Возврат ЗаписьXML.Закрыть();
		КонецЕсли;
		Возврат Строка(ТД);
	Исключение
		ВызватьИсключение СтрШаблон("Не удалось сериализовать макет %1: %2", ИмяДляОшибки, ОписаниеОшибки());
	КонецПопытки;
КонецФункции

Функция МенеджерКоллекцииПоОбъекту(МД)
	ПолноеИмя = МД.ПолноеИмя();
	Если СтрНачинаетсяС(ПолноеИмя, "Справочник.") Тогда                Возврат Справочники;                       КонецЕсли;
	Если СтрНачинаетсяС(ПолноеИмя, "Документ.") Тогда                  Возврат Документы;                         КонецЕсли;
	Если СтрНачинаетсяС(ПолноеИмя, "Отчет.") Тогда                     Возврат Отчеты;                            КонецЕсли;
	Если СтрНачинаетсяС(ПолноеИмя, "Обработка.") Тогда                 Возврат Обработки;                         КонецЕсли;
	Если СтрНачинаетсяС(ПолноеИмя, "ПланВидовХарактеристик.") Тогда    Возврат ПланыВидовХарактеристик;           КонецЕсли;
	Если СтрНачинаетсяС(ПолноеИмя, "ПланСчетов.") Тогда                Возврат ПланыСчетов;                       КонецЕсли;
	Если СтрНачинаетсяС(ПолноеИмя, "ПланВидовРасчета.") Тогда          Возврат ПланыВидовРасчета;                 КонецЕсли;
	Если СтрНачинаетсяС(ПолноеИмя, "ПланОбмена.") Тогда                Возврат ПланыОбмена;                       КонецЕсли;
	Если СтрНачинаетсяС(ПолноеИмя, "БизнесПроцесс.") Тогда             Возврат БизнесПроцессы;                    КонецЕсли;
	Если СтрНачинаетсяС(ПолноеИмя, "Задача.") Тогда                    Возврат Задачи;                            КонецЕсли;
	Если СтрНачинаетсяС(ПолноеИмя, "РегистрСведений.") Тогда           Возврат РегистрыСведений;                  КонецЕсли;
	Если СтрНачинаетсяС(ПолноеИмя, "РегистрНакопления.") Тогда         Возврат РегистрыНакопления;                КонецЕсли;
	Если СтрНачинаетсяС(ПолноеИмя, "РегистрБухгалтерии.") Тогда        Возврат РегистрыБухгалтерии;               КонецЕсли;
	Если СтрНачинаетсяС(ПолноеИмя, "РегистрРасчета.") Тогда            Возврат РегистрыРасчета;                   КонецЕсли;
	Возврат Неопределено;
КонецФункции

// Возвращает метаданные основной СКД отчёта (имя свойства зависит от версии платформы).
Функция ОсновнаяСхемаОтчета(ОтчетМД)

	Если ОтчетМД = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	Попытка
		Возврат ОтчетМД.ОсновнаяСхемаКомпоновкиДанных;
	Исключение
	КонецПопытки;
	Попытка
		Возврат ОтчетМД.МакетОсновнойСхемыКомпоновкиДанных;
	Исключение
	КонецПопытки;
	Возврат Неопределено;

КонецФункции

#КонецОбласти
