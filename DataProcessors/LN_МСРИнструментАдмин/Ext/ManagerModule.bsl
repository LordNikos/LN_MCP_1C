#Область get_event_log

Процедура ДобавитьGetEventLog(Инструменты)

	Параметры = Новый Массив;
	Параметры.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"start_date", "string", "Начальная дата (yyyy-MM-ddTHH:mm:ss)", , Ложь));
	Параметры.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"end_date", "string", "Конечная дата (yyyy-MM-ddTHH:mm:ss)", , Ложь));
	Параметры.Добавить(mcp_Метаданные.ПараметрИнструментаМассив(
		"levels", "string",
		"Массив уровней: Info | Warning | Error | Note (либо русские аналоги).",
		Ложь, "Info,Warning,Error,Note"));
	Параметры.Добавить(mcp_Метаданные.ПараметрИнструментаМассив(
		"events", "string", "Массив имён событий (например MCP.tool.execute_query.Ошибка).", Ложь));
	Параметры.Добавить(mcp_Метаданные.ПараметрИнструментаМассив(
		"metadata_types", "string", "Полные имена МД для фильтра (Справочник.X, Документ.Y).", Ложь));
	Параметры.Добавить(mcp_Метаданные.ПараметрИнструментаМассив(
		"users", "string", "Массив имён пользователей или их UUID.", Ложь));
	Параметры.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"computer", "string", "Имя компьютера (точное совпадение).", , Ложь));
	Параметры.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"comment_substring", "string", "Подстрока в комментарии (нативный фильтр платформы).", , Ложь));
	Параметры.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"transaction_status", "string",
		"Статус транзакции: Committed | RolledBack | NotApplicable | Unfinished.",
		, Ложь,
		"Committed,RolledBack,NotApplicable,Unfinished"));
	Параметры.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"page_size", "number", "Размер страницы (по умолчанию 100, потолок 1000).", 100));
	Параметры.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"cursor", "string",
		"Base64-курсор следующей страницы (поле next_cursor из предыдущего ответа). Пусто — первая страница.",
		, Ложь));
	Параметры.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"max_items", "number",
		"DEPRECATED: используйте page_size. Если задан — переопределяет page_size.", , Ложь));

	mcp_Метаданные.ДобавитьИнструмент(
		Инструменты,
		"get_event_log",
		"Выгружает журнал регистрации с курсорной пагинацией (без пропусков и дублей в пределах одной секунды)."
			+ " Возвращает entries, count, has_more, next_cursor. Поддерживает мульти-фильтры (массивы) по уровню/"
			+ "событию/МД/пользователям, точное совпадение по компьютеру, подстроку в комментарии и статус транзакции.",
		mcp_Метаданные.СхемаПараметровИнструмента(Параметры));

КонецПроцедуры

Функция ВыполнитьGetEventLog(Аргументы)

	Отбор = Новый Структура;

	// Парсим курсор
	КурсорLastDate = '00010101';
	КурсорOffset = 0;
	Если Аргументы.Свойство("cursor") И ЗначениеЗаполнено(Аргументы.cursor) Тогда
		ДекодКурсор = ДекодироватьКурсор(Аргументы.cursor);
		Если ДекодКурсор <> Неопределено Тогда
			Если ДекодКурсор.Свойство("last_date") Тогда
				КурсорLastDate = РазобратьДату(ДекодКурсор.last_date);
			КонецЕсли;
			Если ДекодКурсор.Свойство("offset_in_second") Тогда
				КурсорOffset = Макс(0, Цел(ДекодКурсор.offset_in_second));
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;

	Если ЗначениеЗаполнено(КурсорLastDate) Тогда
		Отбор.Вставить("ДатаНачала", КурсорLastDate);
	ИначеЕсли Аргументы.Свойство("start_date") И ЗначениеЗаполнено(Аргументы.start_date) Тогда
		Отбор.Вставить("ДатаНачала", РазобратьДату(Аргументы.start_date));
	КонецЕсли;
	Если Аргументы.Свойство("end_date") И ЗначениеЗаполнено(Аргументы.end_date) Тогда
		Отбор.Вставить("ДатаОкончания", РазобратьДату(Аргументы.end_date));
	КонецЕсли;

	// Уровни (массив)
	Если Аргументы.Свойство("levels") И ТипЗнч(Аргументы.levels) = Тип("Массив") Тогда
		МассивУровней = Новый Массив;
		Для Каждого УровеньСтрока Из Аргументы.levels Цикл
			Ур = ПривестиУровень(УровеньСтрока);
			Если Ур <> Неопределено Тогда
				МассивУровней.Добавить(Ур);
			КонецЕсли;
		КонецЦикла;
		Если МассивУровней.Количество() > 0 Тогда
			Отбор.Вставить("Уровень", МассивУровней);
		КонецЕсли;
	КонецЕсли;

	// События
	Если Аргументы.Свойство("events") И ТипЗнч(Аргументы.events) = Тип("Массив")
		И Аргументы.events.Количество() > 0 Тогда
		Отбор.Вставить("Событие", Аргументы.events);
	КонецЕсли;

	// Метаданные
	Если Аргументы.Свойство("metadata_types") И ТипЗнч(Аргументы.metadata_types) = Тип("Массив") Тогда
		МассивМД = Новый Массив;
		Для Каждого ИмяМД Из Аргументы.metadata_types Цикл
			ОбъектМД = Метаданные.НайтиПоПолномуИмени(ИмяМД);
			Если ОбъектМД <> Неопределено Тогда
				МассивМД.Добавить(ОбъектМД);
			КонецЕсли;
		КонецЦикла;
		Если МассивМД.Количество() > 0 Тогда
			Отбор.Вставить("Метаданные", МассивМД);
		КонецЕсли;
	КонецЕсли;

	// Пользователи (имя или UUID)
	Если Аргументы.Свойство("users") И ТипЗнч(Аргументы.users) = Тип("Массив") Тогда
		МассивПользователей = НормализоватьСписокПользователей(Аргументы.users);
		Если МассивПользователей.Количество() > 0 Тогда
			Отбор.Вставить("Пользователь", МассивПользователей);
		КонецЕсли;
	КонецЕсли;

	Если Аргументы.Свойство("computer") И ЗначениеЗаполнено(Аргументы.computer) Тогда
		Отбор.Вставить("Компьютер", Аргументы.computer);
	КонецЕсли;

	Если Аргументы.Свойство("comment_substring") И ЗначениеЗаполнено(Аргументы.comment_substring) Тогда
		Отбор.Вставить("Комментарий", Аргументы.comment_substring);
	КонецЕсли;

	// Статус транзакции
	Если Аргументы.Свойство("transaction_status") И ЗначениеЗаполнено(Аргументы.transaction_status) Тогда
		СтатусЗначение = ПривестиСтатусТранзакции(Аргументы.transaction_status);
		Если СтатусЗначение <> Неопределено Тогда
			МассивСтатусов = Новый Массив;
			МассивСтатусов.Добавить(СтатусЗначение);
			Отбор.Вставить("СтатусТранзакции", МассивСтатусов);
		КонецЕсли;
	КонецЕсли;

	РазмерСтраницы = ?(Аргументы.Свойство("page_size"), Аргументы.page_size, 100);
	Если Аргументы.Свойство("max_items") И ЗначениеЗаполнено(Аргументы.max_items) Тогда
		РазмерСтраницы = Аргументы.max_items;
	КонецЕсли;
	Если РазмерСтраницы <= 0 Тогда РазмерСтраницы = 100; КонецЕсли;
	Если РазмерСтраницы > 1000 Тогда РазмерСтраницы = 1000; КонецЕсли;

	// Курсорная пагинация (паттерн ROCTUP):
	// выгружаем РазмерСтраницы + КурсорOffset + 1 записей (для определения has_more),
	// сортируем с tie-breakers, пропускаем КурсорOffset записей с датой == КурсорLastDate,
	// берём РазмерСтраницы следующих, считаем has_more, формируем next_cursor.
	ЛимитВыгрузки = РазмерСтраницы + КурсорOffset + 1;

	Записи = Новый ТаблицаЗначений;
	ВыгрузитьЖурналРегистрации(Записи, Отбор, , , ЛимитВыгрузки);
	Записи.Сортировать("Дата, Сеанс, Событие, Пользователь, ПредставлениеМетаданных, ПредставлениеДанных");

	Результат = Новый Массив;
	Пропущено = 0;
	Взято = 0;
	ПоследняяДатаОтданная = '00010101';
	Для Каждого Стр Из Записи Цикл
		// Пропускаем уже отданные записи с КурсорLastDate
		Если Пропущено < КурсорOffset И Стр.Дата = КурсорLastDate Тогда
			Пропущено = Пропущено + 1;
			Продолжить;
		КонецЕсли;
		Если Взято >= РазмерСтраницы Тогда
			Прервать;
		КонецЕсли;
		Запись = Новый Структура;
		Запись.Вставить("date",                 Стр.Дата);
		Запись.Вставить("level",                Строка(Стр.Уровень));
		Запись.Вставить("event",                Стр.Событие);
		Запись.Вставить("event_presentation",   Стр.ПредставлениеСобытия);
		Запись.Вставить("user",                 Строка(Стр.Пользователь));
		Запись.Вставить("user_name",            Стр.ИмяПользователя);
		Запись.Вставить("computer",             Стр.Компьютер);
		Запись.Вставить("application",          Стр.ИмяПриложения);
		Запись.Вставить("session",              Стр.Сеанс);
		Запись.Вставить("connection",           Стр.Соединение);
		Запись.Вставить("metadata",             Стр.ПредставлениеМетаданных);
		Запись.Вставить("data",                 Стр.ПредставлениеДанных);
		Запись.Вставить("transaction_status",   Строка(Стр.СтатусТранзакции));
		Запись.Вставить("comment",              LN_МСРКодирование.ОбрезатьСтроку(Стр.Комментарий, 1000));
		Результат.Добавить(Запись);
		ПоследняяДатаОтданная = Стр.Дата;
		Взято = Взято + 1;
	КонецЦикла;

	HasMore = (Записи.Количество() > Пропущено + Взято);

	NextCursor = "";
	Если HasMore И Результат.Количество() > 0 Тогда
		// Считаем, сколько записей с датой ПоследняяДатаОтданная уже отдано суммарно
		ВсегоОтданоВPosledней = 0;
		Если ПоследняяДатаОтданная = КурсорLastDate Тогда
			ВсегоОтданоВPosledней = КурсорOffset; // те, что пропустили в начале
		КонецЕсли;
		Для Каждого ЗапЛП Из Результат Цикл
			Если ЗапЛП.date = ПоследняяДатаОтданная Тогда
				ВсегоОтданоВPosledней = ВсегоОтданоВPosledней + 1;
			КонецЕсли;
		КонецЦикла;
		NextCursor = ЗакодироватьКурсор(ПоследняяДатаОтданная, ВсегоОтданоВPosledней);
	КонецЕсли;

	Возврат Новый Структура("entries, count, has_more, next_cursor",
		Результат, Результат.Количество(), HasMore, NextCursor);

КонецФункции

Функция ЗакодироватьКурсор(LastDate, OffsetInSecond)
	JSONТекст = СтрШаблон(
		"{""last_date"":""%1"",""offset_in_second"":%2}",
		XMLСтрока(LastDate),
		Формат(OffsetInSecond, "ЧДЦ=0; ЧГ=0"));
	Возврат Base64Строка(ПолучитьДвоичныеДанныеИзСтроки(JSONТекст, "UTF-8", Ложь));
КонецФункции

Функция ДекодироватьКурсор(Курсор)
	Попытка
		Двоичные = Base64Значение(Курсор);
		JSONТекст = ПолучитьСтрокуИзДвоичныхДанных(Двоичные, "UTF-8");
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(JSONТекст);
		Возврат ПрочитатьJSON(ЧтениеJSON, Истина);
	Исключение
		Возврат Неопределено;
	КонецПопытки;
КонецФункции

Функция РазобратьДату(Текст)
	Попытка
		Возврат XMLЗначение(Тип("Дата"), Текст);
	Исключение
		Возврат '00010101';
	КонецПопытки;
КонецФункции

Функция ПривестиУровень(Текст)
	Т = ВРег(СокрЛП(Строка(Текст)));
	Если Т = "INFO"        Или Т = "INFORMATION"  Или Т = "ИНФОРМАЦИЯ"     Тогда Возврат УровеньЖурналаРегистрации.Информация;       КонецЕсли;
	Если Т = "WARNING"     Или Т = "ПРЕДУПРЕЖДЕНИЕ"                       Тогда Возврат УровеньЖурналаРегистрации.Предупреждение;   КонецЕсли;
	Если Т = "ERROR"       Или Т = "ОШИБКА"                                Тогда Возврат УровеньЖурналаРегистрации.Ошибка;          КонецЕсли;
	Если Т = "NOTE"        Или Т = "ПРИМЕЧАНИЕ"                            Тогда Возврат УровеньЖурналаРегистрации.Примечание;      КонецЕсли;
	Возврат Неопределено;
КонецФункции

Функция ПривестиСтатусТранзакции(Текст)
	Т = ВРег(СокрЛП(Строка(Текст)));
	Если Т = "COMMITTED"      Тогда Возврат СтатусТранзакцииЗаписиЖурналаРегистрации.Зафиксирована; КонецЕсли;
	Если Т = "ROLLEDBACK"     Тогда Возврат СтатусТранзакцииЗаписиЖурналаРегистрации.Отменена;     КонецЕсли;
	Если Т = "NOTAPPLICABLE"  Тогда Возврат СтатусТранзакцииЗаписиЖурналаРегистрации.НетТранзакции; КонецЕсли;
	Если Т = "UNFINISHED"     Тогда Возврат СтатусТранзакцииЗаписиЖурналаРегистрации.НеЗавершена;   КонецЕсли;
	Возврат Неопределено;
КонецФункции

Функция НормализоватьСписокПользователей(СписокПользователей)

	Результат = Новый Массив;
	Для Каждого ИмяПользователя Из СписокПользователей Цикл
		Значение = СокрЛП(Строка(ИмяПользователя));
		Если НЕ ЗначениеЗаполнено(Значение) Тогда
			Продолжить;
		КонецЕсли;
		ПользовательИБ = Неопределено;
		Если СтрДлина(Значение) = 36
			И Сред(Значение, 9, 1) = "-" И Сред(Значение, 14, 1) = "-"
			И Сред(Значение, 19, 1) = "-" И Сред(Значение, 24, 1) = "-" Тогда
			Попытка
				ПользовательИБ = ПользователиИнформационнойБазы.НайтиПоУникальномуИдентификатору(
					Новый УникальныйИдентификатор(Значение));
			Исключение
			КонецПопытки;
		КонецЕсли;
		Если ПользовательИБ = Неопределено Тогда
			ПользовательИБ = ПользователиИнформационнойБазы.НайтиПоИмени(Значение);
		КонецЕсли;
		Если ПользовательИБ <> Неопределено Тогда
			Результат.Добавить(ПользовательИБ);
		Иначе
			Результат.Добавить(Значение);
		КонецЕсли;
	КонецЦикла;
	Возврат Результат;

КонецФункции

#КонецОбласти

#Область get_access_rights

Процедура ДобавитьGetAccessRights(Инструменты)

	Параметры = Новый Массив;
	Параметры.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"object_name", "string", "Полное имя объекта МД (например ""Справочник.Контрагенты"")", , Истина));

	mcp_Метаданные.ДобавитьИнструмент(
		Инструменты,
		"get_access_rights",
		"Возвращает структуру прав текущего пользователя на объект МД: чтение, добавление, изменение, удаление, "
			+ "проведение, отмена проведения, интерактивное чтение и т.д.",
		mcp_Метаданные.СхемаПараметровИнструмента(Параметры));

КонецПроцедуры

Функция ВыполнитьGetAccessRights(Аргументы)

	ИмяОбъекта = ?(Аргументы.Свойство("object_name"), Аргументы.object_name, "");
	Если НЕ ЗначениеЗаполнено(ИмяОбъекта) Тогда
		ВызватьИсключение "Параметр object_name обязателен";
	КонецЕсли;

	МД = Метаданные.НайтиПоПолномуИмени(ИмяОбъекта);
	Если МД = Неопределено Тогда
		ВызватьИсключение "Объект метаданных не найден: " + ИмяОбъекта;
	КонецЕсли;

	Права = "Чтение,Добавление,Изменение,Удаление,Проведение,ОтменаПроведения,"
		+ "ИнтерактивноеЧтение,ИнтерактивноеДобавление,ИнтерактивноеИзменение,ИнтерактивноеУдаление,"
		+ "Просмотр,Редактирование,ВводПоСтроке";

	Результат = Новый Структура;
	Результат.Вставить("object", МД.ПолноеИмя());
	Результат.Вставить("user", Строка(ПользователиИнформационнойБазы.ТекущийПользователь()));

	Доступы = Новый Структура;
	Для Каждого Право Из СтрРазделить(Права, ",", Ложь) Цикл
		Попытка
			Доступы.Вставить(СокрЛП(Право), ПравоДоступа(СокрЛП(Право), МД));
		Исключение
			// Право может не применяться к данному типу — пропускаем тихо
		КонецПопытки;
	КонецЦикла;
	Результат.Вставить("rights", Доступы);

	Возврат Результат;

КонецФункции

#КонецОбласти
