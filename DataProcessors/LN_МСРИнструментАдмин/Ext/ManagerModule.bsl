//LN++ ManagerModule обработки LN_МСРИнструментАдмин
// Tools:
//   - get_event_log         — выгрузка журнала регистрации (мульти-фильтры + cursor)
//   - get_last_error        — последняя ошибка из ЖР одной короткой структурой (шорткат)
//   - get_access_rights     — проверка прав текущего/указанного пользователя на объект МД
//   - get_setting           — чтение значения из РегистрСведений.LN_МСРНастройки по ключу
//   - set_setting           — запись/обновление значения в РегистрСведений.LN_МСРНастройки
//

Процедура ДобавитьИнструменты(Инструменты) Экспорт

	ДобавитьGetEventLog(Инструменты);
	ДобавитьGetLastError(Инструменты);
	ДобавитьGetAccessRights(Инструменты);
	ДобавитьGetSetting(Инструменты);
	ДобавитьSetSetting(Инструменты);
	ДобавитьSamplingTools(Инструменты);

КонецПроцедуры

Функция ВыполнитьИнструмент(ИмяИнструмента, Аргументы) Экспорт

	Если ИмяИнструмента = "get_event_log" Тогда
		Возврат ВыполнитьGetEventLog(Аргументы);
	ИначеЕсли ИмяИнструмента = "get_last_error" Тогда
		Возврат ВыполнитьGetLastError(Аргументы);
	ИначеЕсли ИмяИнструмента = "get_access_rights" Тогда
		Возврат ВыполнитьGetAccessRights(Аргументы);
	ИначеЕсли ИмяИнструмента = "get_setting" Тогда
		Возврат ВыполнитьGetSetting(Аргументы);
	ИначеЕсли ИмяИнструмента = "set_setting" Тогда
		Возврат ВыполнитьSetSetting(Аргументы);
	ИначеЕсли ИмяИнструмента = "request_sampling" Тогда
		Возврат ВыполнитьRequestSampling(Аргументы);
	ИначеЕсли ИмяИнструмента = "pull_pending_sampling" Тогда
		Возврат ВыполнитьPullPendingSampling(Аргументы);
	ИначеЕсли ИмяИнструмента = "submit_sampling_result" Тогда
		Возврат ВыполнитьSubmitSamplingResult(Аргументы);
	ИначеЕсли ИмяИнструмента = "get_sampling_result" Тогда
		Возврат ВыполнитьGetSamplingResult(Аргументы);
	Иначе
		ВызватьИсключение "Неизвестный инструмент: " + ИмяИнструмента;
	КонецЕсли;

КонецФункции

#Область sampling

Процедура ДобавитьSamplingTools(Инструменты)

	// request_sampling — server-side инициированный запрос на сэмплинг.
	Параметры = Новый Массив;
	Параметры.Добавить(mcp_Метаданные.ПараметрИнструмента("messages", "array",
		"Массив сообщений {role, content} для LLM (MCP-формат). Минимум одно сообщение user.", , Истина));
	Параметры.Добавить(mcp_Метаданные.ПараметрИнструмента("system_prompt", "string",
		"Опц.: системный prompt", , Ложь));
	Параметры.Добавить(mcp_Метаданные.ПараметрИнструмента("max_tokens", "number",
		"Опц.: лимит токенов ответа LLM", , Ложь));
	Параметры.Добавить(mcp_Метаданные.ПараметрИнструмента("model_preferences", "object",
		"Опц.: подсказки клиенту, какую LLM использовать (hints, costPriority, speedPriority, intelligencePriority).",
		, Ложь));
	mcp_Метаданные.ДобавитьИнструмент(Инструменты, "request_sampling",
		"Создаёт запрос на сэмплинг (LLM call) в очередь LN_МСРОчередьСэмплинга."
			+ " Возвращает sample_id; клиент-агент должен опросить pull_pending_sampling, выполнить LLM-вызов"
			+ " и вернуть submit_sampling_result. Результат забирается через get_sampling_result.",
		mcp_Метаданные.СхемаПараметровИнструмента(Параметры));

	// pull_pending_sampling
	Параметры = Новый Массив;
	mcp_Метаданные.ДобавитьИнструмент(Инструменты, "pull_pending_sampling",
		"Забирает следующий pending-запрос из очереди (FIFO). Переводит его в статус in_progress."
			+ " Возвращает sample_id и payload (messages, system_prompt и т.д.). Если очередь пуста — found=false.",
		mcp_Метаданные.СхемаПараметровИнструмента(Параметры));

	// submit_sampling_result
	Параметры = Новый Массив;
	Параметры.Добавить(mcp_Метаданные.ПараметрИнструмента("sample_id", "string", "ID запроса (из pull_pending_sampling)", , Истина));
	Параметры.Добавить(mcp_Метаданные.ПараметрИнструмента("content", "object",
		"Содержимое ответа LLM (MCP-формат: { role: 'assistant', content: { type: 'text', text: '...' }, model: '...', stopReason: '...' }).",
		, Истина));
	Параметры.Добавить(mcp_Метаданные.ПараметрИнструмента("error", "string",
		"Если LLM упал — текст ошибки. Тогда статус будет failed.", , Ложь));
	mcp_Метаданные.ДобавитьИнструмент(Инструменты, "submit_sampling_result",
		"Возвращает результат LLM-сэмплинга в очередь. Статус переходит в completed или failed.",
		mcp_Метаданные.СхемаПараметровИнструмента(Параметры));

	// get_sampling_result
	Параметры = Новый Массив;
	Параметры.Добавить(mcp_Метаданные.ПараметрИнструмента("sample_id", "string", "ID запроса", , Истина));
	mcp_Метаданные.ДобавитьИнструмент(Инструменты, "get_sampling_result",
		"Возвращает текущее состояние sample_id: { status:'pending|in_progress|completed|failed', content, error }.",
		mcp_Метаданные.СхемаПараметровИнструмента(Параметры));

КонецПроцедуры

Функция ВыполнитьRequestSampling(Аргументы)
	Полезное = Новый Структура;
	Если Аргументы.Свойство("messages") Тогда
		Полезное.Вставить("messages", Аргументы.messages);
	Иначе
		ВызватьИсключение "messages обязателен";
	КонецЕсли;
	Если Аргументы.Свойство("system_prompt") Тогда Полезное.Вставить("system_prompt", Аргументы.system_prompt); КонецЕсли;
	Если Аргументы.Свойство("max_tokens") Тогда Полезное.Вставить("max_tokens", Аргументы.max_tokens); КонецЕсли;
	Если Аргументы.Свойство("model_preferences") Тогда Полезное.Вставить("model_preferences", Аргументы.model_preferences); КонецЕсли;
	Идентификатор = LN_МСРСэмплинг.СоздатьЗапрос(Полезное);
	Возврат Новый Структура("sample_id, status", Идентификатор, "pending");
КонецФункции

Функция ВыполнитьPullPendingSampling(Аргументы)
	Заявка = LN_МСРСэмплинг.ЗабратьСледующий();
	Если Заявка = Неопределено Тогда
		Возврат Новый Структура("found", Ложь);
	КонецЕсли;
	Возврат Новый Структура("found, sample_id, payload, created_at",
		Истина, Заявка.sample_id, Заявка.payload, Заявка.created_at);
КонецФункции

Функция ВыполнитьSubmitSamplingResult(Аргументы)
	Идентификатор = ?(Аргументы.Свойство("sample_id"), СокрЛП(Строка(Аргументы.sample_id)), "");
	Если Не ЗначениеЗаполнено(Идентификатор) Тогда ВызватьИсключение "sample_id обязателен"; КонецЕсли;
	Содержимое = ?(Аргументы.Свойство("content"), Аргументы.content, Неопределено);
	Ошибка = ?(Аргументы.Свойство("error"), Строка(Аргументы.error), "");
	LN_МСРСэмплинг.ЗавершитьЗапрос(Идентификатор, Содержимое, Ошибка);
	Возврат Новый Структура("submitted, sample_id, status",
		Истина, Идентификатор, ?(ЗначениеЗаполнено(Ошибка), "failed", "completed"));
КонецФункции

Функция ВыполнитьGetSamplingResult(Аргументы)
	Идентификатор = ?(Аргументы.Свойство("sample_id"), СокрЛП(Строка(Аргументы.sample_id)), "");
	Если Не ЗначениеЗаполнено(Идентификатор) Тогда ВызватьИсключение "sample_id обязателен"; КонецЕсли;
	Состояние = LN_МСРСэмплинг.Прочитать(Идентификатор);
	Если Состояние = Неопределено Тогда
		Возврат Новый Структура("found, sample_id", Ложь, Идентификатор);
	КонецЕсли;
	Возврат Новый Структура("found, sample_id, status, content, error, created_at, updated_at",
		Истина, Состояние.sample_id, Состояние.status, Состояние.content, Состояние.error,
		Состояние.created_at, Состояние.updated_at);
КонецФункции

#КонецОбласти

#Область get_last_error

Процедура ДобавитьGetLastError(Инструменты)

	Параметры = Новый Массив;
	Параметры.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"hours", "number",
		"За сколько последних часов искать ошибку (по умолчанию 24). Максимум — 24*30.",
		24));
	Параметры.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"event_substring", "string",
		"Опц.: подстрока в имени события. Полезно, чтобы взять последнюю ошибку конкретной подсистемы.",
		, Ложь));

	mcp_Метаданные.ДобавитьИнструмент(
		Инструменты,
		"get_last_error",
		"Возвращает последнюю ошибку из журнала регистрации компактной структурой"
			+ " {date, event, metadata, data, comment}. Шорткат поверх get_event_log для типового"
			+ " запроса агента «расскажи что упало».",
		mcp_Метаданные.СхемаПараметровИнструмента(Параметры));

КонецПроцедуры

Функция ВыполнитьGetLastError(Аргументы)

	Часов = ?(Аргументы.Свойство("hours"), Число(Аргументы.hours), 24);
	Если Часов <= 0 Тогда Часов = 24; КонецЕсли;
	Если Часов > 24 * 30 Тогда Часов = 24 * 30; КонецЕсли;

	Отбор = Новый Структура;
	Отбор.Вставить("ДатаНачала", ТекущаяДатаСеанса() - Часов * 3600);
	Отбор.Вставить("Уровень", УровеньЖурналаРегистрации.Ошибка);
	Если Аргументы.Свойство("event_substring") И ЗначениеЗаполнено(Аргументы.event_substring) Тогда
		Отбор.Вставить("Событие", Аргументы.event_substring);
	КонецЕсли;

	Колонки = "Дата,Уровень,Событие,ПредставлениеСобытия,ПредставлениеМетаданных,ПредставлениеДанных,Комментарий";
	Записи = Новый ТаблицаЗначений;
	ВыгрузитьЖурналРегистрации(Записи, Отбор, Колонки, , 1);

	Если Записи.Количество() = 0 Тогда
		Возврат Новый Структура("found, message", Ложь, "За указанный период ошибок не найдено");
	КонецЕсли;
	Стр = Записи[0];
	Возврат Новый Структура(
		"found, date, event, event_presentation, metadata, data, comment",
		Истина,
		Стр.Дата,
		Стр.Событие,
		Стр.ПредставлениеСобытия,
		Стр.ПредставлениеМетаданных,
		Стр.ПредставлениеДанных,
		LN_МСРКодирование.ОбрезатьСтроку(Стр.Комментарий, 2000));

КонецФункции

#КонецОбласти

#Область get_setting_set_setting

Процедура ДобавитьGetSetting(Инструменты)

	Параметры = Новый Массив;
	Параметры.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"key", "string",
		"Ключ настройки. Стандартные ключи: execute_code_default_safe, audit_enabled, cache_ttl_seconds, "
			+ "max_response_chars, default_response_format.",
		, Истина));
	mcp_Метаданные.ДобавитьИнструмент(
		Инструменты,
		"get_setting",
		"Читает значение настройки из РегистрСведений.LN_МСРНастройки по ключу."
			+ " Возвращает {key, value, found}.",
		mcp_Метаданные.СхемаПараметровИнструмента(Параметры));

КонецПроцедуры

Процедура ДобавитьSetSetting(Инструменты)

	Параметры = Новый Массив;
	Параметры.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"key", "string", "Ключ настройки", , Истина));
	Параметры.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"value", "string", "Значение настройки (строкой; для булевых: true/false)", , Истина));
	Параметры.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"description", "string", "Опциональное описание настройки", , Ложь));
	mcp_Метаданные.ДобавитьИнструмент(
		Инструменты,
		"set_setting",
		"Записывает/обновляет настройку в РегистрСведений.LN_МСРНастройки."
			+ " Транзакционно. Возвращает {key, value, updated}.",
		mcp_Метаданные.СхемаПараметровИнструмента(Параметры));

КонецПроцедуры

Функция ВыполнитьGetSetting(Аргументы)
	Ключ = ?(Аргументы.Свойство("key"), Аргументы.key, "");
	Если НЕ ЗначениеЗаполнено(Ключ) Тогда ВызватьИсключение "Параметр key обязателен"; КонецЕсли;
	Запрос = Новый Запрос(
		"ВЫБРАТЬ Значение, Комментарий ИЗ РегистрСведений.LN_МСРНастройки ГДЕ Ключ = &Ключ");
	Запрос.УстановитьПараметр("Ключ", Ключ);
	Выборка = Запрос.Выполнить().Выбрать();
	Результат = Новый Структура("key, value, description, found", Ключ, "", "", Ложь);
	Если Выборка.Следующий() Тогда
		Результат.value = Выборка.Значение;
		Результат.description = Выборка.Комментарий;
		Результат.found = Истина;
	КонецЕсли;
	Возврат Результат;
КонецФункции

Функция ВыполнитьSetSetting(Аргументы)
	Ключ = ?(Аргументы.Свойство("key"), Аргументы.key, "");
	Значение = ?(Аргументы.Свойство("value"), Строка(Аргументы.value), "");
	Описание = ?(Аргументы.Свойство("description"), Строка(Аргументы.description), "");
	Если НЕ ЗначениеЗаполнено(Ключ) Тогда ВызватьИсключение "Параметр key обязателен"; КонецЕсли;
	НаборЗаписей = РегистрыСведений.LN_МСРНастройки.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Ключ.Установить(Ключ);
	Запись = НаборЗаписей.Добавить();
	Запись.Ключ = Ключ;
	Запись.Значение = Значение;
	Запись.Комментарий = Описание;
	НаборЗаписей.Записать();
	Возврат Новый Структура("key, value, updated", Ключ, Значение, Истина);
КонецФункции

