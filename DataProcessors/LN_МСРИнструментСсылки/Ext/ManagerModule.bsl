//LN++ ManagerModule обработки LN_МСРИнструментСсылки
// Tools:
//   - get_object_by_link            — объект по навигационной ссылке (e1cib://...)
//   - get_link_of_object            — навигационная ссылка по полному имени и коду/номеру
//   - find_references_to_object     — поиск ссылок на указанный объект
//

Процедура ДобавитьИнструменты(Инструменты) Экспорт

	ДобавитьGetObjectByLink(Инструменты);
	ДобавитьGetLinkOfObject(Инструменты);
	ДобавитьFindReferencesToObject(Инструменты);

КонецПроцедуры

Функция ВыполнитьИнструмент(ИмяИнструмента, Аргументы) Экспорт

	Если ИмяИнструмента = "get_object_by_link" Тогда
		Возврат ВыполнитьGetObjectByLink(Аргументы);
	ИначеЕсли ИмяИнструмента = "get_link_of_object" Тогда
		Возврат ВыполнитьGetLinkOfObject(Аргументы);
	ИначеЕсли ИмяИнструмента = "find_references_to_object" Тогда
		Возврат ВыполнитьFindReferencesToObject(Аргументы);
	Иначе
		ВызватьИсключение "Неизвестный инструмент: " + ИмяИнструмента;
	КонецЕсли;

КонецФункции

#Область get_object_by_link

Процедура ДобавитьGetObjectByLink(Инструменты)

	Параметры = Новый Массив;
	Параметры.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"link", "string", "Навигационная ссылка 1С (e1cib://data/Справочник.Контрагенты?ref=...)", , Истина));

	mcp_Метаданные.ДобавитьИнструмент(
		Инструменты,
		"get_object_by_link",
		"Возвращает структуру объекта 1С (реквизиты + ТЧ) по его навигационной ссылке.",
		mcp_Метаданные.СхемаПараметровИнструмента(Параметры));

КонецПроцедуры

Функция ВыполнитьGetObjectByLink(Аргументы)

	URL = ?(Аргументы.Свойство("link"), Аргументы.link, "");
	Если НЕ ЗначениеЗаполнено(URL) Тогда
		ВызватьИсключение "Параметр link обязателен";
	КонецЕсли;

	Попытка
		Ссылка = LN_МСРКодирование.ПолучитьСсылкуИзНавигационнойСсылки(URL);
	Исключение
		ВызватьИсключение "Не удалось разобрать ссылку: " + ОписаниеОшибки();
	КонецПопытки;

	Если Ссылка = Неопределено Тогда
		ВызватьИсключение "Ссылка пустая или объект не найден: " + URL;
	КонецЕсли;

	Объект = Ссылка.ПолучитьОбъект();
	Если Объект = Неопределено Тогда
		ВызватьИсключение "Объект по ссылке не существует или удалён";
	КонецЕсли;

	Результат = Новый Структура;
	Результат.Вставить("type", Ссылка.Метаданные().ПолноеИмя());
	Результат.Вставить("presentation", Строка(Объект));
	Результат.Вставить("uuid", Строка(Объект.УникальныйИдентификатор()));

	// Реквизиты объекта (плоские)
	Реквизиты = Новый Структура;
	Для Каждого Рек Из Объект.Метаданные().Реквизиты Цикл
		Реквизиты.Вставить(Рек.Имя, LN_МСРКодирование.БезопасноеЗначение(Объект[Рек.Имя]));
	КонецЦикла;
	Результат.Вставить("attributes", Реквизиты);

	// Табличные части
	Попытка
		ТабличныеЧасти = Новый Структура;
		Для Каждого Т Из Объект.Метаданные().ТабличныеЧасти Цикл
			Строки = Новый Массив;
			Для Каждого СтрокаТЧ Из Объект[Т.Имя] Цикл
				Стр = Новый Структура;
				Для Каждого Рек Из Т.Реквизиты Цикл
					Стр.Вставить(Рек.Имя, LN_МСРКодирование.БезопасноеЗначение(СтрокаТЧ[Рек.Имя]));
				КонецЦикла;
				Строки.Добавить(Стр);
			КонецЦикла;
			ТабличныеЧасти.Вставить(Т.Имя, Строки);
		КонецЦикла;
		Если ТабличныеЧасти.Количество() > 0 Тогда
			Результат.Вставить("tabular_sections", ТабличныеЧасти);
		КонецЕсли;
	Исключение
		// объект без ТЧ
	КонецПопытки;

	Возврат Результат;

КонецФункции

#КонецОбласти

#Область get_link_of_object

Процедура ДобавитьGetLinkOfObject(Инструменты)

	Параметры = Новый Массив;
	Параметры.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"object_name", "string", "Полное имя объекта (например ""Справочник.Контрагенты"")", , Истина));
	Параметры.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"code", "string", "Код или номер объекта (для справочников/документов)", , Ложь));
	Параметры.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"description", "string", "Наименование объекта (поиск по наименованию)", , Ложь));

	mcp_Метаданные.ДобавитьИнструмент(
		Инструменты,
		"get_link_of_object",
		"Возвращает навигационную ссылку 1С для указанного объекта. Поиск по code или description.",
		mcp_Метаданные.СхемаПараметровИнструмента(Параметры));

КонецПроцедуры

Функция ВыполнитьGetLinkOfObject(Аргументы)

	ИмяОбъекта = ?(Аргументы.Свойство("object_name"), Аргументы.object_name, "");
	Если НЕ ЗначениеЗаполнено(ИмяОбъекта) Тогда
		ВызватьИсключение "Параметр object_name обязателен";
	КонецЕсли;
	МД = Метаданные.НайтиПоПолномуИмени(ИмяОбъекта);
	Если МД = Неопределено Тогда
		ВызватьИсключение "Объект метаданных не найден: " + ИмяОбъекта;
	КонецЕсли;

	Код         = ?(Аргументы.Свойство("code"), Аргументы.code, "");
	Описание    = ?(Аргументы.Свойство("description"), Аргументы.description, "");

	Менеджер = ПолучитьМенеджерОбъекта(ИмяОбъекта);
	Ссылка = Неопределено;

	Если ЗначениеЗаполнено(Код) Тогда
		Ссылка = Менеджер.НайтиПоКоду(Код);
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(Ссылка) И ЗначениеЗаполнено(Описание) Тогда
		Ссылка = Менеджер.НайтиПоНаименованию(Описание, Истина);
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(Ссылка) Тогда
		ВызватьИсключение "Объект не найден: " + ИмяОбъекта + " code=" + Код + " desc=" + Описание;
	КонецЕсли;

	Возврат Новый Структура("link, presentation",
		ПолучитьНавигационнуюСсылку(Ссылка),
		Строка(Ссылка));

КонецФункции

Функция ПолучитьМенеджерОбъекта(ПолноеИмя)

	Части = СтрРазделить(ПолноеИмя, ".", Ложь);
	Если Части.Количество() <> 2 Тогда
		ВызватьИсключение "Неверный формат полного имени: " + ПолноеИмя;
	КонецЕсли;
	Категория = Части[0];
	Имя       = Части[1];
	Если Категория = "Справочник" Тогда
		Возврат Справочники[Имя];
	ИначеЕсли Категория = "Документ" Тогда
		Возврат Документы[Имя];
	ИначеЕсли Категория = "ПланВидовХарактеристик" Тогда
		Возврат ПланыВидовХарактеристик[Имя];
	ИначеЕсли Категория = "Перечисление" Тогда
		Возврат Перечисления[Имя];
	Иначе
		ВызватьИсключение "Неподдерживаемая категория для get_link_of_object: " + Категория;
	КонецЕсли;

КонецФункции

#КонецОбласти

#Область find_references_to_object

Процедура ДобавитьFindReferencesToObject(Инструменты)

	Параметры = Новый Массив;
	Параметры.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"link", "string", "Навигационная ссылка объекта, ссылки на который нужно найти", , Истина));
	Параметры.Добавить(mcp_Метаданные.ПараметрИнструмента(
		"max_items", "number", "Максимум результатов (по умолчанию 100)", 100));

	mcp_Метаданные.ДобавитьИнструмент(
		Инструменты,
		"find_references_to_object",
		"Возвращает массив объектов, ссылающихся на указанную ссылку. Использует НайтиПоСсылкам.",
		mcp_Метаданные.СхемаПараметровИнструмента(Параметры));

КонецПроцедуры

Функция ВыполнитьFindReferencesToObject(Аргументы)

	URL = ?(Аргументы.Свойство("link"), Аргументы.link, "");
	Если НЕ ЗначениеЗаполнено(URL) Тогда
		ВызватьИсключение "Параметр link обязателен";
	КонецЕсли;
	МаксЭлементов = ?(Аргументы.Свойство("max_items"), Аргументы.max_items, 100);

	Ссылка = LN_МСРКодирование.ПолучитьСсылкуИзНавигационнойСсылки(URL);
	Если Ссылка = Неопределено Тогда
		ВызватьИсключение "Не удалось получить ссылку: " + URL;
	КонецЕсли;

	МассивСсылок = Новый Массив;
	МассивСсылок.Добавить(Ссылка);
	ТаблицаНайденных = НайтиПоСсылкам(МассивСсылок);

	Результат = Новый Массив;
	Счетчик = 0;
	Для Каждого СтрокаНайдено Из ТаблицаНайденных Цикл
		Если Счетчик >= МаксЭлементов Тогда
			Прервать;
		КонецЕсли;
		НайденнаяСсылка = СтрокаНайдено.Ссылка;
		Результат.Добавить(Новый Структура("type, presentation, link",
			НайденнаяСсылка.Метаданные().ПолноеИмя(),
			Строка(НайденнаяСсылка),
			ПолучитьНавигационнуюСсылку(НайденнаяСсылка)));
		Счетчик = Счетчик + 1;
	КонецЦикла;
	Возврат Новый Структура("references, count, truncated",
		Результат, Результат.Количество(), Счетчик >= МаксЭлементов И ТаблицаНайденных.Количество() > МаксЭлементов);

КонецФункции

#КонецОбласти
