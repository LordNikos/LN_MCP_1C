//LN++ Общий модуль LN_МСРКодирование
// Кодирование значений для MCP-ответов: JSON / JSON-compact / TOON.
// TOON (Token-Oriented Object Notation) сокращает токены LLM на 30-60% для табличных данных
// за счёт вынесения схемы в заголовок (имена колонок 1 раз) и отказа от лишних { } " :.
// Совместимая (не каноническая) реализация TOON для серверного использования внутри 1С.
//
// Внешний контракт:
//   ЗначениеВJSON(Значение, Компактный = Ложь)  -> Строка
//   ЗначениеВTOON(Значение)                     -> Строка
//   ТаблицаВTOON(Таблица, КолонкиЯвно = "")     -> Строка
//   СогласоватьФормат(Формат)                   -> "json" | "json-compact" | "toon"
//   ОбрезатьСтроку(Строка, Лимит)               -> Строка
//

#Область ПрограммныйИнтерфейс

// Сериализует произвольное значение в JSON.
// Параметры:
//   Значение   - Произвольный - структура / массив / соответствие / простой тип.
//   Компактный - Булево       - Истина = без переносов и отступов (минимум байт).
Функция ЗначениеВJSON(Значение, Компактный = Ложь) Экспорт

	Запись = Новый ЗаписьJSON;
	Параметры = Новый ПараметрыЗаписиJSON(
		?(Компактный, ПереносСтрокJSON.Нет, ПереносСтрокJSON.Авто),
		?(Компактный, "", Символы.Таб),
		Ложь);
	Запись.УстановитьСтроку(Параметры);
	ЗаписатьJSON(Запись, Значение);
	Возврат Запись.Закрыть();

КонецФункции

// Сериализует значение в TOON.
// Если Значение — массив однотипных структур или ТаблицаЗначений с одинаковыми ключами — формируется
// табличное представление; иначе fallback на компактный JSON-подобный TOON.
Функция ЗначениеВTOON(Значение) Экспорт

	Если ТипЗнч(Значение) = Тип("ТаблицаЗначений") Тогда
		Возврат ТаблицаВTOON(Значение);
	КонецЕсли;

	Если ТипЗнч(Значение) = Тип("Массив") Тогда
		Если ОднородныйМассивСтруктур(Значение) Тогда
			Возврат МассивСтруктурВTOON(Значение);
		КонецЕсли;
	КонецЕсли;

	Возврат ОдиночноеЗначениеВTOON(Значение, 0);

КонецФункции

// Превращает таблицу значений в TOON.
// КолонкиЯвно — строка имен колонок через запятую (если нужно зафиксировать порядок).
Функция ТаблицаВTOON(Таблица, КолонкиЯвно = "") Экспорт

	КолонкиИмена = ИменаКолонокТаблицы(Таблица, КолонкиЯвно);

	Лог = Новый ЗаписьТекста;
	Лог.УстановитьСтроку();
	Лог.ЗаписатьСтроку("[" + Таблица.Количество() + "]{" + СтрСоединить(КолонкиИмена, ",") + "}");

	Для Каждого Строка Из Таблица Цикл
		Поля = Новый Массив;
		Для Каждого ИмяКолонки Из КолонкиИмена Цикл
			Поля.Добавить(СкалярВTOON(Строка[ИмяКолонки]));
		КонецЦикла;
		Лог.ЗаписатьСтроку(СтрСоединить(Поля, ","));
	КонецЦикла;

	Возврат СокрП(Лог.Закрыть());

КонецФункции

// Нормализует строку формата ответа.
// "json"|"j" -> "json", "compact"|"json-compact" -> "json-compact",
// "toon"|"t" -> "toon", "text"|"text-pipe"|"plain" -> "text-pipe".
// иначе -> "json".
Функция СогласоватьФормат(Формат) Экспорт

	Ф = НРег(СокрЛП(Строка(Формат)));
	Если Ф = "toon" Или Ф = "t" Тогда
		Возврат "toon";
	ИначеЕсли Ф = "compact" Или Ф = "json-compact" Или Ф = "jc" Тогда
		Возврат "json-compact";
	ИначеЕсли Ф = "text" Или Ф = "text-pipe" Или Ф = "plain" Тогда
		Возврат "text-pipe";
	КонецЕсли;
	Возврат "json";

КонецФункции

// Текстовый табличный формат вывода (заголовок + строки через " | ").
// Подходит, если LLM лучше «понимает» простой плоский текст.
// Возвращает Строку. Принимает: Массив структур, ТаблицуЗначений, одну Структуру (становится колонкой ключ|значение)
// или Структуру { columns:[], rows:[Структура,...] } (формат execute_query).
Функция ТаблицаВTextPipe(Значение, Разделитель = " | ") Экспорт

	Если ТипЗнч(Значение) = Тип("Структура") И Значение.Свойство("columns") И Значение.Свойство("rows") Тогда
		Колонки = Значение.columns;
		Возврат СформироватьTextPipe(Колонки, Значение.rows, Разделитель);
	КонецЕсли;
	Если ТипЗнч(Значение) = Тип("ТаблицаЗначений") Тогда
		Колонки = Новый Массив;
		Для Каждого Кол Из Значение.Колонки Цикл
			Колонки.Добавить(Кол.Имя);
		КонецЦикла;
		Строки = Новый Массив;
		Для Каждого Стр Из Значение Цикл
			РСтр = Новый Структура;
			Для Каждого ИмяКолонки Из Колонки Цикл
				РСтр.Вставить(ИмяКолонки, Стр[ИмяКолонки]);
			КонецЦикла;
			Строки.Добавить(РСтр);
		КонецЦикла;
		Возврат СформироватьTextPipe(Колонки, Строки, Разделитель);
	КонецЕсли;
	Если ТипЗнч(Значение) = Тип("Массив") И ОднородныйМассивСтруктур(Значение) И Значение.Количество() > 0 Тогда
		Колонки = Новый Массив;
		Для Каждого КЗ Из Значение[0] Цикл
			Колонки.Добавить(КЗ.Ключ);
		КонецЦикла;
		Возврат СформироватьTextPipe(Колонки, Значение, Разделитель);
	КонецЕсли;
	Если ТипЗнч(Значение) = Тип("Структура") Тогда
		Колонки = Новый Массив;
		Колонки.Добавить("key");
		Колонки.Добавить("value");
		Строки = Новый Массив;
		Для Каждого КЗ Из Значение Цикл
			Стр = Новый Структура("key, value", КЗ.Ключ, КЗ.Значение);
			Строки.Добавить(Стр);
		КонецЦикла;
		Возврат СформироватьTextPipe(Колонки, Строки, Разделитель);
	КонецЕсли;
	// Скаляр / null / прочее — просто СтрокаЗначения
	Возврат Строка(Значение);

КонецФункции

Функция СформироватьTextPipe(Колонки, Строки, Разделитель)
	Буф = Новый ЗаписьТекста;
	Буф.УстановитьСтроку();
	Буф.ЗаписатьСтроку(СтрСоединить(Колонки, Разделитель));
	Для Каждого Стр Из Строки Цикл
		Поля = Новый Массив;
		Для Каждого ИмяКолонки Из Колонки Цикл
			Значение = "";
			Попытка
				Значение = Стр[ИмяКолонки];
			Исключение
			КонецПопытки;
			Если Значение = Неопределено Или Значение = Null Тогда
				Поля.Добавить("");
			Иначе
				Поля.Добавить(СтрЗаменить(Строка(Значение), Символы.ПС, " "));
			КонецЕсли;
		КонецЦикла;
		Буф.ЗаписатьСтроку(СтрСоединить(Поля, Разделитель));
	КонецЦикла;
	Возврат СокрП(Буф.Закрыть());
КонецФункции

// Универсальное обрезание длинных строк с маркером.
Функция ОбрезатьСтроку(Строка, Лимит) Экспорт

	Если Лимит <= 0 Тогда
		Возврат Строка;
	КонецЕсли;
	Если СтрДлина(Строка) <= Лимит Тогда
		Возврат Строка;
	КонецЕсли;
	Возврат Лев(Строка, Лимит) + "…[обрезано: " + (СтрДлина(Строка) - Лимит) + " симв.]";

КонецФункции

// Рекурсивно приводит произвольное значение 1С к JSON-сериализуемому виду.
// Глубина рекурсии ограничена (по умолчанию 6) — после порога возвращается строка "<max_depth>".
// Поддерживаются: примитивы, Массив, ФиксированныйМассив, Структура, ФиксированнаяСтруктура,
// Соответствие (как массив пар key/value), ТаблицаЗначений, СсылкиНаОбъектыИБ, УникальныйИдентификатор,
// ХранилищеЗначения (как "<ХранилищеЗначения>"). Остальные типы — Строка(Значение) с fallback.
Функция БезопасноеЗначение(Значение, Глубина = 0) Экспорт

	Если Глубина > 6 Тогда
		Возврат "<max_depth>";
	КонецЕсли;
	Если Значение = Неопределено Или Значение = Null Тогда
		Возврат Null;
	КонецЕсли;

	ТипЗначения = ТипЗнч(Значение);

	Если ТипЗначения = Тип("Строка") Или ТипЗначения = Тип("Число")
		Или ТипЗначения = Тип("Булево") Или ТипЗначения = Тип("Дата") Тогда
		Возврат Значение;
	КонецЕсли;

	Если ТипЗначения = Тип("УникальныйИдентификатор") Тогда
		Возврат Строка(Значение);
	КонецЕсли;

	Если ТипЗначения = Тип("Массив") Или ТипЗначения = Тип("ФиксированныйМассив") Тогда
		Результат = Новый Массив;
		Для Каждого Элемент Из Значение Цикл
			Результат.Добавить(БезопасноеЗначение(Элемент, Глубина + 1));
		КонецЦикла;
		Возврат Результат;
	КонецЕсли;

	Если ТипЗначения = Тип("Структура") Или ТипЗначения = Тип("ФиксированнаяСтруктура") Тогда
		Результат = Новый Структура;
		Для Каждого КЗ Из Значение Цикл
			Результат.Вставить(КЗ.Ключ, БезопасноеЗначение(КЗ.Значение, Глубина + 1));
		КонецЦикла;
		Возврат Результат;
	КонецЕсли;

	Если ТипЗначения = Тип("Соответствие") Или ТипЗначения = Тип("ФиксированноеСоответствие") Тогда
		Результат = Новый Массив;
		Для Каждого КЗ Из Значение Цикл
			Результат.Добавить(Новый Структура("key, value",
				БезопасноеЗначение(КЗ.Ключ, Глубина + 1),
				БезопасноеЗначение(КЗ.Значение, Глубина + 1)));
		КонецЦикла;
		Возврат Результат;
	КонецЕсли;

	Попытка
		Если ТипЗначения = Тип("ТаблицаЗначений") Тогда
			Результат = Новый Массив;
			Для Каждого СтрокаТаблицы Из Значение Цикл
				СтрокаРезультата = Новый Структура;
				Для Каждого Колонка Из Значение.Колонки Цикл
					СтрокаРезультата.Вставить(Колонка.Имя,
						БезопасноеЗначение(СтрокаТаблицы[Колонка.Имя], Глубина + 1));
				КонецЦикла;
				Результат.Добавить(СтрокаРезультата);
			КонецЦикла;
			Возврат Результат;
		КонецЕсли;
	Исключение
	КонецПопытки;

	Если ТипЗначения = Тип("ХранилищеЗначения") Тогда
		Возврат "<ХранилищеЗначения>";
	КонецЕсли;

	// Ссылочные типы — даём расширенное описание (для последующего восстановления)
	Попытка
		МД = Значение.Метаданные();
		Если МД <> Неопределено Тогда
			УникИдент = "";
			Попытка
				УникИдент = Строка(Значение.УникальныйИдентификатор());
			Исключение
			КонецПопытки;
			Возврат Новый Структура("type, presentation, uuid, link",
				МД.ПолноеИмя(),
				Строка(Значение),
				УникИдент,
				?(ЗначениеЗаполнено(УникИдент), ПолучитьНавигационнуюСсылку(Значение), ""));
		КонецЕсли;
	Исключение
	КонецПопытки;

	Попытка
		Возврат Строка(Значение);
	Исключение
		Возврат "<" + Строка(ТипЗначения) + ">";
	КонецПопытки;

КонецФункции

// Проверяет, является ли строка ISO-8601 датой/датавременем (yyyy-MM-dd[Thh:mm[:ss]][Z|+hh:mm]).
// Используется в execute_query для авто-конвертации параметров из JSON, в котором нет нативного типа Дата.
Функция СтрокаISO8601(Текст) Экспорт

	Если ТипЗнч(Текст) <> Тип("Строка") Тогда
		Возврат Ложь;
	КонецЕсли;
	Длина = СтрДлина(Текст);
	Если Длина < 10 Или Длина > 35 Тогда
		Возврат Ложь;
	КонецЕсли;
	// минимальный «yyyy-MM-dd» — цифры и дефисы в фиксированных позициях
	Если Сред(Текст, 5, 1) <> "-" Или Сред(Текст, 8, 1) <> "-" Тогда
		Возврат Ложь;
	КонецЕсли;
	Для Поз = 1 По 4 Цикл
		С = Сред(Текст, Поз, 1);
		Если СтрНайти("0123456789", С) = 0 Тогда
			Возврат Ложь;
		КонецЕсли;
	КонецЦикла;
	Возврат Истина;

КонецФункции

// Преобразует строку ISO-8601 в значение типа Дата.
// Поддерживает yyyy-MM-dd и yyyy-MM-ddThh:mm:ss (T заменяется на пробел для XMLЗначение).
Функция ISO8601ВДату(Текст) Экспорт

	Если Не СтрокаISO8601(Текст) Тогда
		ВызватьИсключение "Строка не является ISO-8601 датой: " + Текст;
	КонецЕсли;
	Попытка
		Возврат XMLЗначение(Тип("Дата"), Текст);
	Исключение
	КонецПопытки;
	ТекстСПробелом = СтрЗаменить(Текст, "T", " ");
	Попытка
		Возврат XMLЗначение(Тип("Дата"), ТекстСПробелом);
	Исключение
		ВызватьИсключение "Не удалось преобразовать ISO-8601 в дату: " + Текст;
	КонецПопытки;

КонецФункции
Функция ПолучитьСсылкуИзНавигационнойСсылки(НавигационнаяСсылка) Экспорт

	Позиция1 = СтрНайти(НавигационнаяСсылка, "e1cib/data/");
	Позиция2 = СтрНайти(НавигационнаяСсылка, "?ref=");
	Если Позиция1 = 0 Или Позиция2 = 0 Тогда
		ВызватьИсключение "Некорректная навигационная ссылка: " + НавигационнаяСсылка;
	КонецЕсли;

	ПредставлениеТипа = Сред(НавигационнаяСсылка, Позиция1 + 11, Позиция2 - Позиция1 - 11);
	Шаблон = ЗначениеВСтрокуВнутр(ПредопределенноеЗначение(ПредставлениеТипа + ".ПустаяСсылка"));
	Идентификатор = Сред(НавигационнаяСсылка, Позиция2 + 5);
	ЗначениеСсылки = СтрЗаменить(Шаблон, "00000000000000000000000000000000", Идентификатор);
	Возврат ЗначениеИзСтрокиВнутр(ЗначениеСсылки);

КонецФункции

// Кодирует значение в выбранный формат и собирает финальный текст ответа.
// Формат: "json" | "json-compact" | "toon".
Функция ЗакодироватьОтвет(Значение, Формат = "json", ЛимитСимволов = 0) Экспорт

	ФорматН = СогласоватьФормат(Формат);
	Если ФорматН = "toon" Тогда
		Результат = ЗначениеВTOON(Значение);
	ИначеЕсли ФорматН = "json-compact" Тогда
		Результат = ЗначениеВJSON(Значение, Истина);
	ИначеЕсли ФорматН = "text-pipe" Тогда
		Результат = ТаблицаВTextPipe(Значение);
	Иначе
		Результат = ЗначениеВJSON(Значение, Ложь);
	КонецЕсли;
	Если ЛимитСимволов > 0 Тогда
		Результат = ОбрезатьСтроку(Результат, ЛимитСимволов);
	КонецЕсли;
	Возврат Результат;

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ОднородныйМассивСтруктур(Массив)

	Если Массив.Количество() = 0 Тогда
		Возврат Ложь;
	КонецЕсли;
	ЭталонныеКлючи = Неопределено;
	Для Каждого Элемент Из Массив Цикл
		Если ТипЗнч(Элемент) <> Тип("Структура") Тогда
			Возврат Ложь;
		КонецЕсли;
		Ключи = Новый Массив;
		Для Каждого КЗ Из Элемент Цикл
			Ключи.Добавить(КЗ.Ключ);
		КонецЦикла;
		ЭтоКлючи = СтрСоединить(Ключи, ",");
		Если ЭталонныеКлючи = Неопределено Тогда
			ЭталонныеКлючи = ЭтоКлючи;
		ИначеЕсли ЭталонныеКлючи <> ЭтоКлючи Тогда
			Возврат Ложь;
		КонецЕсли;
	КонецЦикла;
	Возврат Истина;

КонецФункции

Функция МассивСтруктурВTOON(Массив)

	Если Массив.Количество() = 0 Тогда
		Возврат "[0]{}";
	КонецЕсли;

	Эталон = Массив[0];
	Имена = Новый Массив;
	Для Каждого КЗ Из Эталон Цикл
		Имена.Добавить(КЗ.Ключ);
	КонецЦикла;

	Лог = Новый ЗаписьТекста;
	Лог.УстановитьСтроку();
	Лог.ЗаписатьСтроку("[" + Массив.Количество() + "]{" + СтрСоединить(Имена, ",") + "}");

	Для Каждого Элемент Из Массив Цикл
		Поля = Новый Массив;
		Для Каждого ИмяПоля Из Имена Цикл
			Поля.Добавить(СкалярВTOON(Элемент[ИмяПоля]));
		КонецЦикла;
		Лог.ЗаписатьСтроку(СтрСоединить(Поля, ","));
	КонецЦикла;

	Возврат СокрП(Лог.Закрыть());

КонецФункции

Функция ИменаКолонокТаблицы(Таблица, КолонкиЯвно)

	Если ЗначениеЗаполнено(КолонкиЯвно) Тогда
		Результат = СтрРазделить(КолонкиЯвно, ",", Ложь);
		Для К = 0 По Результат.ВГраница() Цикл
			Результат[К] = СокрЛП(Результат[К]);
		КонецЦикла;
		Возврат Результат;
	КонецЕсли;
	Результат = Новый Массив;
	Для Каждого Кол Из Таблица.Колонки Цикл
		Результат.Добавить(Кол.Имя);
	КонецЦикла;
	Возврат Результат;

КонецФункции

Функция СкалярВTOON(Значение)

	Если Значение = Неопределено Или Значение = Null Тогда
		Возврат "";
	КонецЕсли;
	Если ТипЗнч(Значение) = Тип("Булево") Тогда
		Возврат ?(Значение, "1", "0");
	КонецЕсли;
	Если ТипЗнч(Значение) = Тип("Дата") Тогда
		Возврат Формат(Значение, "ДФ=yyyy-MM-ddTHH:mm:ss");
	КонецЕсли;
	Если ТипЗнч(Значение) = Тип("Число") Тогда
		Возврат Формат(Значение, "ЧРД=.; ЧГ=0");
	КонецЕсли;
	Текст = Строка(Значение);
	Если СтрНайти(Текст, ",") > 0 Или СтрНайти(Текст, """") > 0 Или СтрНайти(Текст, Символы.ПС) > 0 Тогда
		Текст = СтрЗаменить(Текст, """", """""");
		Текст = """" + Текст + """";
	КонецЕсли;
	Возврат Текст;

КонецФункции

Функция ОдиночноеЗначениеВTOON(Значение, Уровень)

	ТипЗначения = ТипЗнч(Значение);
	Если ТипЗначения = Тип("Структура") Или ТипЗначения = Тип("Соответствие") Тогда
		Строки = Новый Массив;
		Для Каждого КЗ Из Значение Цикл
			Строки.Добавить(КЗ.Ключ + ":" + СкалярВTOON(КЗ.Значение));
		КонецЦикла;
		Возврат "{" + СтрСоединить(Строки, ",") + "}";
	ИначеЕсли ТипЗначения = Тип("Массив") Тогда
		Поля = Новый Массив;
		Для Каждого Элемент Из Значение Цикл
			Поля.Добавить(СкалярВTOON(Элемент));
		КонецЦикла;
		Возврат "[" + Значение.Количество() + "]" + СтрСоединить(Поля, ",");
	КонецЕсли;
	Возврат СкалярВTOON(Значение);

КонецФункции

