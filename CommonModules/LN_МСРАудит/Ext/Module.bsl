//LN++ Общий модуль LN_МСРАудит
// Логирует каждый вызов MCP-tool в РегистрСведений.LN_МСРАудитВызовов
// и при ошибках/предупреждениях — в журнал регистрации (категория MCP.tool.<имя>).
//
//   НачалоЗамера(ИмяИнструмента, Аргументы, АдресКлиента = "") -> Структура (контекст замера)
//   ЗавершитьЗамерУспех(Контекст, РазмерОтветаБайт)
//   ЗавершитьЗамерОшибка(Контекст, ТекстОшибки)
//

#Область ПрограммныйИнтерфейс

Функция НачалоЗамера(ИмяИнструмента, Аргументы, АдресКлиента = "") Экспорт

	Контекст = Новый Структура;
	Контекст.Вставить("Идентификатор", Строка(Новый УникальныйИдентификатор));
	Контекст.Вставить("ИмяИнструмента", ИмяИнструмента);
	Контекст.Вставить("Аргументы", LN_МСРКодирование.ОбрезатьСтроку(LN_МСРКодирование.ЗначениеВJSON(Аргументы, Истина), 2000));
	Контекст.Вставить("АдресКлиента", АдресКлиента);
	Контекст.Вставить("Начало", ТекущаяУниверсальнаяДатаВМиллисекундах());
	Возврат Контекст;

КонецФункции

Процедура ЗавершитьЗамерУспех(Контекст, РазмерОтветаБайт = 0) Экспорт

	ЗаписатьИтог(Контекст, Истина, "", РазмерОтветаБайт);

КонецПроцедуры

Процедура ЗавершитьЗамерОшибка(Контекст, ТекстОшибки) Экспорт

	ЗаписатьИтог(Контекст, Ложь, ТекстОшибки, 0);

	// дополнительно в журнал регистрации
	ЗаписьЖурналаРегистрации(
		"MCP.tool." + Контекст.ИмяИнструмента + ".Ошибка",
		УровеньЖурналаРегистрации.Ошибка,
		,
		,
		ТекстОшибки);

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ЗаписатьИтог(Контекст, Успех, ТекстОшибки, РазмерОтветаБайт)

	Длительность = ТекущаяУниверсальнаяДатаВМиллисекундах() - Контекст.Начало;

	УстановитьПривилегированныйРежим(Истина);
	НаборЗаписей = РегистрыСведений.LN_МСРАудитВызовов.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.ИдентификаторВызова.Установить(Контекст.Идентификатор);
	Запись = НаборЗаписей.Добавить();
	Запись.Период              = ТекущаяДатаСеанса();
	Запись.ИдентификаторВызова = Контекст.Идентификатор;
	Запись.ИмяИнструмента      = Контекст.ИмяИнструмента;
	Запись.Параметры           = Контекст.Аргументы;
	Запись.Длительность        = Длительность;
	Запись.Успех               = Успех;
	Запись.ТекстОшибки         = LN_МСРКодирование.ОбрезатьСтроку(ТекстОшибки, 1024);
	Запись.АдресКлиента        = Контекст.АдресКлиента;
	Запись.РазмерОтветаБайт    = РазмерОтветаБайт;
	НаборЗаписей.Записать();
	УстановитьПривилегированныйРежим(Ложь);

КонецПроцедуры

#КонецОбласти
//LN--
