//LN++ Общий модуль LN_МСРАвтодополнение
// Реализация MCP-метода completion/complete (спецификация MCP 2025-03-26).
//
// Запрос клиента имеет вид:
//   { "ref": { "type":"ref/prompt"|"ref/resource", "name": "...uri or prompt name..." },
//     "argument": { "name": "<arg>", "value": "<typed-prefix>" } }
//
// В этой реализации мы игнорируем привязку к конкретному prompt/resource и работаем по
// имени аргумента: object_name, form_name, key — типовые «адреса» нашего сервера.
// Если приходит неизвестное имя — возвращается пустой массив (а не ошибка): по спецификации.

#Область ПрограммныйИнтерфейс

// Главная точка входа из mcp_APIBackend.
// Параметры — структура MCP-completion-запроса (поля ref, argument).
// Возвращает структуру { completion: { values:[...], total:N, hasMore:булево } }.
Функция ВыполнитьАвтодополнение(Параметры) Экспорт

	Имя = "";
	Префикс = "";
	Если Параметры.Свойство("argument") И ТипЗнч(Параметры.argument) = Тип("Структура") Тогда
		Если Параметры.argument.Свойство("name") Тогда Имя = Строка(Параметры.argument.name); КонецЕсли;
		Если Параметры.argument.Свойство("value") Тогда Префикс = Строка(Параметры.argument.value); КонецЕсли;
	КонецЕсли;

	// Контекст родителя (имя prompt/resource) — используется для object_name → form_name.
	РодительИмя = "";
	Если Параметры.Свойство("ref") И ТипЗнч(Параметры.ref) = Тип("Структура") И Параметры.ref.Свойство("name") Тогда
		РодительИмя = Строка(Параметры.ref.name);
	КонецЕсли;

	// Контекст уже введённых полей (если клиент шлёт прежние values вместе с текущим)
	КонтекстныеЗначения = Новый Структура;
	Если Параметры.Свойство("context") И ТипЗнч(Параметры.context) = Тип("Структура")
		И Параметры.context.Свойство("arguments") И ТипЗнч(Параметры.context.arguments) = Тип("Структура") Тогда
		КонтекстныеЗначения = Параметры.context.arguments;
	КонецЕсли;

	ИмяНРег = НРег(СокрЛП(Имя));
	Значения = Новый Массив;
	Если ИмяНРег = "object_name" Тогда
		Значения = ИменаОбъектовМетаданных(Префикс);
	ИначеЕсли ИмяНРег = "form_name" Тогда
		ПривязкаКОбъекту = "";
		Если КонтекстныеЗначения.Свойство("object_name") Тогда
			ПривязкаКОбъекту = Строка(КонтекстныеЗначения.object_name);
		ИначеЕсли ЗначениеЗаполнено(РодительИмя) Тогда
			ПривязкаКОбъекту = РодительИмя;
		КонецЕсли;
		Значения = ИменаФорм(ПривязкаКОбъекту, Префикс);
	ИначеЕсли ИмяНРег = "key" Или ИмяНРег = "setting_key" Тогда
		Значения = КлючиНастроек(Префикс);
	ИначеЕсли ИмяНРег = "topic" Тогда
		Значения = ТопикиСинтаксисаBSL(Префикс);
	КонецЕсли;

	// Спецификация MCP: total — общее число; values отдаётся в массиве (макс 100).
	Всего = Значения.Количество();
	Если Всего > 100 Тогда
		Усечённый = Новый Массив;
		Для Индекс = 0 По 99 Цикл Усечённый.Добавить(Значения[Индекс]); КонецЦикла;
		Значения = Усечённый;
	КонецЕсли;

	Завершение = Новый Структура;
	Завершение.Вставить("values", Значения);
	Завершение.Вставить("total", Всего);
	Завершение.Вставить("hasMore", Всего > 100);
	Возврат Новый Структура("completion", Завершение);

КонецФункции

#КонецОбласти

#Область Источники

Функция ИменаОбъектовМетаданных(Префикс)
	Результат = Новый Массив;
	Префикс = СокрЛП(Префикс);
	НижнийПрефикс = НРег(Префикс);
	Категории = Новый Массив;
	Категории.Добавить(Новый Структура("Имя, ИмяРусское", "Catalogs",              "Справочник"));
	Категории.Добавить(Новый Структура("Имя, ИмяРусское", "Documents",             "Документ"));
	Категории.Добавить(Новый Структура("Имя, ИмяРусское", "Constants",             "Константа"));
	Категории.Добавить(Новый Структура("Имя, ИмяРусское", "ChartsOfCharacteristicTypes", "ПланВидовХарактеристик"));
	Категории.Добавить(Новый Структура("Имя, ИмяРусское", "ChartsOfAccounts",      "ПланСчетов"));
	Категории.Добавить(Новый Структура("Имя, ИмяРусское", "ChartsOfCalculationTypes", "ПланВидовРасчета"));
	Категории.Добавить(Новый Структура("Имя, ИмяРусское", "InformationRegisters",  "РегистрСведений"));
	Категории.Добавить(Новый Структура("Имя, ИмяРусское", "AccumulationRegisters", "РегистрНакопления"));
	Категории.Добавить(Новый Структура("Имя, ИмяРусское", "AccountingRegisters",   "РегистрБухгалтерии"));
	Категории.Добавить(Новый Структура("Имя, ИмяРусское", "CalculationRegisters",  "РегистрРасчета"));
	Категории.Добавить(Новый Структура("Имя, ИмяРусское", "BusinessProcesses",     "БизнесПроцесс"));
	Категории.Добавить(Новый Структура("Имя, ИмяРусское", "Tasks",                 "Задача"));
	Категории.Добавить(Новый Структура("Имя, ИмяРусское", "Enums",                 "Перечисление"));
	Категории.Добавить(Новый Структура("Имя, ИмяРусское", "Reports",               "Отчет"));
	Категории.Добавить(Новый Структура("Имя, ИмяРусское", "DataProcessors",        "Обработка"));
	Категории.Добавить(Новый Структура("Имя, ИмяРусское", "CommonModules",         "ОбщийМодуль"));
	Категории.Добавить(Новый Структура("Имя, ИмяРусское", "HTTPServices",          "HTTPСервис"));
	Категории.Добавить(Новый Структура("Имя, ИмяРусское", "WebServices",           "WebСервис"));
	Категории.Добавить(Новый Структура("Имя, ИмяРусское", "ExchangePlans",         "ПланОбмена"));

	Для Каждого Категория Из Категории Цикл
		Коллекция = Метаданные[Категория.Имя];
		Для Каждого МД Из Коллекция Цикл
			Полное = Категория.ИмяРусское + "." + МД.Имя;
			Если Не ЗначениеЗаполнено(Префикс) Или СтрНачинаетсяС(НРег(Полное), НижнийПрефикс) Тогда
				Результат.Добавить(Полное);
				Если Результат.Количество() >= 500 Тогда Прервать; КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		Если Результат.Количество() >= 500 Тогда Прервать; КонецЕсли;
	КонецЦикла;
	Возврат Результат;
КонецФункции

Функция ИменаФорм(ИмяОбъекта, Префикс)
	Результат = Новый Массив;
	Если Не ЗначениеЗаполнено(ИмяОбъекта) Тогда Возврат Результат; КонецЕсли;
	МД = МетаданныеПоИмени(СокрЛП(ИмяОбъекта));
	Если МД = Неопределено Тогда Возврат Результат; КонецЕсли;
	Попытка
		Формы = МД.Формы;
	Исключение
		Возврат Результат;
	КонецПопытки;
	НижнийПрефикс = НРег(СокрЛП(Префикс));
	Для Каждого Форма Из Формы Цикл
		Если Не ЗначениеЗаполнено(Префикс) Или СтрНачинаетсяС(НРег(Форма.Имя), НижнийПрефикс) Тогда
			Результат.Добавить(Форма.Имя);
		КонецЕсли;
	КонецЦикла;
	Возврат Результат;
КонецФункции

Функция КлючиНастроек(Префикс)
	Результат = Новый Массив;
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ Настройки.Ключ КАК Ключ
	|ИЗ РегистрСведений.LN_МСРНастройки КАК Настройки
	|ГДЕ Настройки.Ключ ПОДОБНО &Префикс
	|УПОРЯДОЧИТЬ ПО Настройки.Ключ";
	Запрос.УстановитьПараметр("Префикс", Префикс + "%");
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Результат.Добавить(Выборка.Ключ);
	КонецЦикла;
	// Плюс «известные» ключи, даже если их пока нет в регистре
	ДляСервера = Новый Массив;
	ДляСервера.Добавить("execute_code_default_safe");
	ДляСервера.Добавить("execute_code_max_chars");
	ДляСервера.Добавить("default_response_format");
	ДляСервера.Добавить("max_response_chars");
	ДляСервера.Добавить("audit_enabled");
	ДляСервера.Добавить("cache_ttl_seconds");
	ДляСервера.Добавить("query_cursor_ttl_seconds");
	ДляСервера.Добавить("allow_custom_tools_registration");
	НижнийПрефикс = НРег(СокрЛП(Префикс));
	Для Каждого Ключ Из ДляСервера Цикл
		Если Результат.Найти(Ключ) = Неопределено
			И (Не ЗначениеЗаполнено(Префикс) Или СтрНачинаетсяС(НРег(Ключ), НижнийПрефикс)) Тогда
			Результат.Добавить(Ключ);
		КонецЕсли;
	КонецЦикла;
	Возврат Результат;
КонецФункции

Функция ТопикиСинтаксисаBSL(Префикс)
	Результат = Новый Массив;
	Базовые = Новый Массив;
	Базовые.Добавить("Запрос"); Базовые.Добавить("РезультатЗапроса"); Базовые.Добавить("ТаблицаЗначений");
	Базовые.Добавить("Структура"); Базовые.Добавить("Соответствие"); Базовые.Добавить("Массив");
	Базовые.Добавить("ХранилищеЗначения"); Базовые.Добавить("ДанныеЖурналаРегистрации");
	Базовые.Добавить("ВыгрузитьЖурналРегистрации"); Базовые.Добавить("Метаданные");
	Базовые.Добавить("УстановитьБезопасныйРежим"); Базовые.Добавить("ТекущаяДатаСеанса");
	НижнийПрефикс = НРег(СокрЛП(Префикс));
	Для Каждого Топик Из Базовые Цикл
		Если Не ЗначениеЗаполнено(Префикс) Или СтрНачинаетсяС(НРег(Топик), НижнийПрефикс) Тогда
			Результат.Добавить(Топик);
		КонецЕсли;
	КонецЦикла;
	Возврат Результат;
КонецФункции

Функция МетаданныеПоИмени(Полное)
	Части = СтрРазделить(Полное, ".", Ложь);
	Если Части.Количество() < 2 Тогда Возврат Неопределено; КонецЕсли;
	КатегорияРусская = Лев(Части[0], 200);
	КатегорияЯнгл = РусскоеНаAнглийское(КатегорияРусская);
	Если КатегорияЯнгл = "" Тогда Возврат Неопределено; КонецЕсли;
	Имя = Части[1];
	Попытка
		Возврат Метаданные[КатегорияЯнгл][Имя];
	Исключение
		Возврат Неопределено;
	КонецПопытки;
КонецФункции

Функция РусскоеНаAнглийское(Категория)
	Соответствие = Новый Соответствие;
	Соответствие.Вставить("Справочник",                  "Catalogs");
	Соответствие.Вставить("Документ",                    "Documents");
	Соответствие.Вставить("Перечисление",                "Enums");
	Соответствие.Вставить("Отчет",                       "Reports");
	Соответствие.Вставить("Обработка",                   "DataProcessors");
	Соответствие.Вставить("РегистрСведений",             "InformationRegisters");
	Соответствие.Вставить("РегистрНакопления",           "AccumulationRegisters");
	Соответствие.Вставить("РегистрБухгалтерии",          "AccountingRegisters");
	Соответствие.Вставить("РегистрРасчета",              "CalculationRegisters");
	Соответствие.Вставить("ПланВидовХарактеристик",      "ChartsOfCharacteristicTypes");
	Соответствие.Вставить("ПланСчетов",                  "ChartsOfAccounts");
	Соответствие.Вставить("ПланВидовРасчета",            "ChartsOfCalculationTypes");
	Соответствие.Вставить("БизнесПроцесс",               "BusinessProcesses");
	Соответствие.Вставить("Задача",                      "Tasks");
	Соответствие.Вставить("ПланОбмена",                  "ExchangePlans");
	Соответствие.Вставить("HTTPСервис",                  "HTTPServices");
	Возврат ?(Соответствие.Получить(Категория) = Неопределено, "", Соответствие.Получить(Категория));
КонецФункции

#КонецОбласти
